---
import BaseLayout from './BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { getImageAlt } from '../config/images';
import CTAContact from '../components/CTAContact.astro';
import FAQ from '../components/FAQ.astro';
import {
  absoluteUrl,
  schemaIds,
  createServiceSchema,
  contentDateModified,
  faqSchemaIfVisible,
  resolveOgImage,
} from '../lib/seo';
import { site } from '../config/site';
import type { BreadcrumbItem } from '../config/site';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'serviceAreas'>;
  service?: CollectionEntry<'services'>;
  area?: CollectionEntry<'areas'>;
}

const { entry, service, area } = Astro.props;
const { title, description, slug, faqs, mainKeyword, ogImage, heroImage, date, updated } = entry.data;
const { Content } = await render(entry);

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'รับซื้อสินค้า', href: '/รับซื้อสินค้าไอที' },
  ...(service ? [{ label: service.data.title, href: `/บริการ/${service.data.slug}` }] : []),
  ...(area ? [{ label: area.data.province, href: `/พื้นที่ให้บริการ/${area.data.slug}` }] : []),
  { label: title },
];

const pageUrl = absoluteUrl(`/รับซื้อ/${slug}`);
const resolvedOgImage = (ogImage && ogImage !== '/images/og/og-service-it.webp')
  ? ogImage
  : (service?.data.ogImage ?? ogImage);
const pageImage = resolveOgImage(resolvedOgImage, heroImage ?? service?.data.heroImage);
const datePublished = date.toISOString();
const dateModified = contentDateModified(date, updated);

const schemaExtras = [
  createServiceSchema({
    pageUrl,
    name: title,
    description,
    serviceType: mainKeyword,
    image: pageImage,
  }),
  ...faqSchemaIfVisible(pageUrl, faqs),
];

const steps = [
  { n: 1, title: 'ส่งรูปผ่าน Line',    desc: 'ส่งรูปสินค้า ระบุรุ่น สภาพ'    },
  { n: 2, title: 'รับราคาเบื้องต้น',   desc: 'ทีมงานประเมินใน 15-30 นาที'    },
  { n: 3, title: 'นัดรับสินค้า',        desc: 'นัดวันเวลารับสินค้าที่สะดวก'   },
  { n: 4, title: 'จ่ายเงินทันที',       desc: 'เงินสด / โอน ทันทีหลังตรวจ'   },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={pageUrl}
  ogImage={resolvedOgImage}
  heroImage={heroImage ?? service?.data.heroImage}
  breadcrumbs={breadcrumbs}
  pageType="WebPage"
  mainEntityId={schemaIds.service(pageUrl)}
  datePublished={datePublished}
  dateModified={dateModified}
  geoPlace={area?.data.province}
  schemaExtras={schemaExtras}
>
  <!-- Page hero -->
  <header class="page-header">
    <div class="container page-header__grid">
      <div>
        <span class="tag tag--orange" style="margin-bottom:.875rem;">
          {area ? area.data.province : 'ภาคอีสาน'}
        </span>
        <h1>{title}</h1>
        <p class="page-header__desc">{description}</p>
        <div class="page-header__cta">
          <a href={site.line} class="btn btn--line" target="_blank" rel="noopener noreferrer">
            แชท Line ประเมินราคา
          </a>
          <a href={`tel:${site.phoneTel}`} class="btn btn--ghost">
            โทร {site.phone}
          </a>
        </div>
      </div>
      {heroImage && (
        <figure class="page-header__figure">
          <OptimizedImage
            src={heroImage}
            alt={getImageAlt(heroImage, `${title} — อำพล เทรดดิ้ง`)}
            loading="eager"
            width={600}
            height={338}
          />
        </figure>
      )}
    </div>
  </header>

  <!-- Content + sidebar -->
  <div class="container content-layout">
    <article class="prose">
      <Content />
    </article>

    <aside class="sidebar">
      <div class="sidebar__box">
        <p class="sidebar__title">ประเมินราคาฟรี</p>
        <div style="display:flex;flex-direction:column;gap:.625rem;">
          <a href={site.line} class="btn btn--line btn--sm" target="_blank" rel="noopener noreferrer">
            แชท Line @webuy
          </a>
          <a href={`tel:${site.phoneTel}`} class="btn btn--phone btn--sm">
            โทร {site.phone}
          </a>
        </div>
      </div>

      {service && (
        <div class="sidebar__box">
          <p class="sidebar__title">บริการที่เกี่ยวข้อง</p>
          <ul class="sidebar__links">
            <li>
              <a href={`/บริการ/${service.data.slug}`}>{service.data.title}</a>
            </li>
          </ul>
        </div>
      )}

      {area && (
        <div class="sidebar__box">
          <p class="sidebar__title">พื้นที่ให้บริการ</p>
          <ul class="sidebar__links">
            <li>
              <a href={`/พื้นที่ให้บริการ/${area.data.slug}`}>{area.data.title}</a>
            </li>
          </ul>
        </div>
      )}
    </aside>
  </div>

  <!-- Steps -->
  <section class="section section--gray">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">วิธีขาย</span>
        <h2>ขายสินค้า{area ? `ใน${area.data.province}` : ''} ง่ายใน 4 ขั้นตอน</h2>
      </div>
      <div class="steps">
        {steps.map((s) => (
          <div class="step">
            <span class="step__number">{s.n}</span>
            <h3 class="step__title">{s.title}</h3>
            <p class="step__desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faqs} />
  <CTAContact title={`${title} — นัดประเมินราคาฟรีวันนี้`} />
</BaseLayout>
