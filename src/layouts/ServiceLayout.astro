---
import BaseLayout from './BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { getImageAlt, serviceThumbnails } from '../config/images';
import CTAContact from '../components/CTAContact.astro';
import FAQ from '../components/FAQ.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ServiceQuickSummary from '../components/ServiceQuickSummary.astro';
import RelatedIntentChips from '../components/RelatedIntentChips.astro';
import InlineServiceCTA from '../components/InlineServiceCTA.astro';
import Reviews from '../components/Reviews.astro';
import {
  absoluteUrl,
  schemaIds,
  createServiceSchema,
  createOfferCatalogSchema,
  contentDateModified,
  faqSchemaIfVisible,
  resolveOgImage,
} from '../lib/seo';
import { site } from '../config/site';
import { sanitizeServiceDisplayText, getIntentChipHeading } from '../config/service-clusters';
import type { BreadcrumbItem } from '../config/site';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'services'>;
  relatedAreas?: CollectionEntry<'serviceAreas'>[];
  otherServices?: CollectionEntry<'services'>[];
  intentChips?: CollectionEntry<'services'>[];
  relatedCards?: CollectionEntry<'services'>[];
}

const { entry, relatedAreas = [], otherServices = [], intentChips = [], relatedCards = [] } = Astro.props;
const { title, h1, description, slug, faqs, mainKeyword, relatedKeywords, ogImage, heroImage, date, updated, quickSummary } =
  entry.data;
const { Content } = await render(entry);

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'บริการ', href: '/รับซื้อสินค้าไอที' },
  { label: title },
];

const pageUrl = absoluteUrl(`/บริการ/${slug}`);
const intentChipHeading = getIntentChipHeading(slug, mainKeyword);
const pageImage = resolveOgImage(ogImage, heroImage);
const dateModified = contentDateModified(date, updated);

let offerCatalogSchema: Record<string, unknown> | null = null;

if (slug === 'รับซื้อคอมพิวเตอร์' || slug === 'รับซื้อ-macbook' || slug === 'รับซื้อ-ipad' || slug === 'รับซื้อ-iphone' || slug === 'รับซื้อกล้อง' || slug === 'รับซื้อคอมบริษัท') {
  
  if (slug === 'รับซื้อคอมพิวเตอร์') {
    offerCatalogSchema = createOfferCatalogSchema({
        pageUrl,
        name: 'รับซื้อคอมพิวเตอร์และอุปกรณ์ไอที',
        items: [
          { name: 'คอมสำนักงาน', url: '/บริการ/รับซื้อคอมสำนักงาน', description: 'รับซื้อคอมสำนักงาน เครื่องแบรนด์เนมทั่วไป' },
          { name: 'คอมประกอบ', url: '/บริการ/รับซื้อคอมประกอบ', description: 'รับซื้อคอมประกอบ Custom PC แยกชิ้น' },
          { name: 'Gaming PC', url: '/บริการ/รับซื้อ-gaming-pc', description: 'รับซื้อคอมเล่นเกม สเปกสูง' },
          { name: 'คอมบริษัท/ยกล็อต', url: '/บริการ/รับซื้อคอมบริษัท', description: 'รับซื้อคอมพิวเตอร์องค์กร ประมูลยกล็อต' },
          { name: 'คอมเสีย/ซากคอม', url: '/บริการ/รับซื้อคอมเสีย', description: 'รับซื้อซากคอม เปิดไม่ติด ตีราคาเป็นอะไหล่' },
          { name: 'อุปกรณ์คอมแยกชิ้น', url: '/บริการ/รับซื้อการ์ดจอ', description: 'รับซื้ออะไหล่คอมพิวเตอร์ เช่น การ์ดจอ CPU RAM' }
        ]
      });
  } else if (slug === 'รับซื้อ-macbook') {
    offerCatalogSchema = createOfferCatalogSchema({
        pageUrl,
        name: 'รับซื้อ MacBook มือสอง หลายรุ่น',
        items: [
          { name: 'MacBook Air', url: '/บริการ/รับซื้อ-macbook-air', description: 'รับซื้อ MacBook Air ชิป M1, M2, M3, M4' },
          { name: 'MacBook Pro', url: '/บริการ/รับซื้อ-macbook-pro', description: 'รับซื้อ MacBook Pro สายตัดต่อ สเปกสูง' },
          { name: 'MacBook M1/M2', url: '/บริการ/รับซื้อ-macbook-m1', description: 'รับซื้อ MacBook ชิป M1 และ M2 หลายรุ่น' },
          { name: 'MacBook M3/M4', url: '/บริการ/รับซื้อ-macbook-m3-m4', description: 'รับซื้อ MacBook ชิปใหม่ล่าสุด M3 และ M4' },
          { name: 'Intel MacBook', url: '/บริการ/รับซื้อ-macbook-intel', description: 'รับซื้อ MacBook Intel รุ่นเก่าปี 2018-2020' },
          { name: 'MacBook เสีย/จอแตก', url: '/บริการ/รับซื้อ-macbook-เสีย', description: 'รับซื้อซาก MacBook เสีย เปิดไม่ติด จอแตก' },
          { name: 'iMac/Mac mini', url: '/บริการ/รับซื้อ-imac-mac-mini', description: 'รับซื้อคอมพิวเตอร์ตั้งโต๊ะ iMac และ Mac mini' }
        ]
      });
  } else if (slug === 'รับซื้อ-ipad') {
    offerCatalogSchema = createOfferCatalogSchema({
        pageUrl,
        name: 'รับซื้อ iPad มือสอง หลายรุ่น',
        items: [
          { name: 'iPad Pro', url: '/บริการ/รับซื้อ-ipad-pro', description: 'รับซื้อ iPad Pro M1, M2, M4 ทุกความจุ' },
          { name: 'iPad Air', url: '/บริการ/รับซื้อ-ipad-air', description: 'รับซื้อ iPad Air 4, 5, M2, M3' },
          { name: 'iPad mini', url: '/บริการ/รับซื้อ-ipad-mini', description: 'รับซื้อ iPad mini 6, A17 Pro' },
          { name: 'iPad Gen', url: '/บริการ/รับซื้อ-ipad-gen', description: 'รับซื้อ iPad Gen 8, 9, 10' },
          { name: 'iPad เสีย/จอแตก', url: '/บริการ/รับซื้อ-ipad-เสีย', description: 'รับซื้อซาก iPad เสีย เปิดไม่ติด จอแตก' },
          { name: 'Apple Pencil', url: '/บริการ/รับซื้อ-apple-pencil', description: 'รับซื้อ Apple Pencil Gen 1, Gen 2, USB-C, Pro' },
          { name: 'Magic Keyboard iPad', url: '/บริการ/รับซื้อ-magic-keyboard-ipad', description: 'รับซื้อ Magic Keyboard และ Smart Keyboard' }
        ]
      });
  } else if (slug === 'รับซื้อ-iphone') {
    offerCatalogSchema = createOfferCatalogSchema({
        pageUrl,
        name: 'รับซื้อ iPhone มือสอง หลายรุ่น',
        items: [
          { name: 'iPhone 17', url: '/บริการ/รับซื้อ-iphone-17', description: 'รับซื้อ iPhone 17 หลายรุ่น หลายความจุ' },
          { name: 'iPhone Pro Max', url: '/บริการ/รับซื้อ-iphone-pro-max', description: 'รับซื้อ iPhone Pro Max หลายซีรีส์ ประเมินตามสภาพ' },
          { name: 'iPhone 16', url: '/บริการ/รับซื้อ-iphone-16', description: 'รับซื้อ iPhone 16, 16 Pro, 16 Pro Max' },
          { name: 'iPhone 15', url: '/บริการ/รับซื้อ-iphone-15', description: 'รับซื้อ iPhone 15, 15 Pro, 15 Pro Max' },
          { name: 'iPhone 14', url: '/บริการ/รับซื้อ-iphone-14', description: 'รับซื้อ iPhone 14, 14 Pro, 14 Pro Max' },
          { name: 'iPhone 13', url: '/บริการ/รับซื้อ-iphone-13', description: 'รับซื้อ iPhone 13, 13 Pro, 13 Pro Max' },
          { name: 'iPhone จอแตก', url: '/บริการ/รับซื้อ-iphone-จอแตก', description: 'รับซื้อ iPhone จอแตก จอเป็นเส้น ทัชไม่ติด' },
          { name: 'iPhone Face ID เสีย', url: '/บริการ/รับซื้อ-iphone-face-id-เสีย', description: 'รับซื้อ iPhone สแกนหน้าไม่ได้' },
          { name: 'iPhone ติด iCloud', url: '/บริการ/รับซื้อ-iphone-ติด-icloud', description: 'รับซื้อ iPhone ติดล็อค ตามเงื่อนไข' },
          { name: 'iPhone เครื่องนอก', url: '/บริการ/รับซื้อ-iphone-เครื่องนอก', description: 'รับซื้อ iPhone โมเดลนอก ติดซิมล็อค' }
        ]
      });
  } else if (slug === 'รับซื้อกล้อง') {
    offerCatalogSchema = createOfferCatalogSchema({
      pageUrl,
      name: 'บริการรับซื้อกล้องและอุปกรณ์ถ่ายภาพมือสอง',
      items: [
        { name: 'กล้อง Canon มือสอง', url: 'https://amphon.co.th/%E0%B8%9A%E0%B8%A3%E0%B8%B4%E0%B8%81%E0%B8%B2%E0%B8%A3/%E0%B8%A3%E0%B8%B1%E0%B8%9A%E0%B8%8B%E0%B8%B7%E0%B9%89%E0%B8%AD%E0%B8%81%E0%B8%A5%E0%B9%89%E0%B8%AD%E0%B8%87-canon', description: 'ประเมินกล้อง Canon มือสองตามรุ่น สภาพ อุปกรณ์ และความต้องการตลาด' },
        { name: 'กล้อง Sony มือสอง', url: 'https://amphon.co.th/%E0%B8%9A%E0%B8%A3%E0%B8%B4%E0%B8%81%E0%B8%B2%E0%B8%A3/%E0%B8%A3%E0%B8%B1%E0%B8%9A%E0%B8%8B%E0%B8%B7%E0%B9%89%E0%B8%AD%E0%B8%81%E0%B8%A5%E0%B9%89%E0%B8%AD%E0%B8%87-sony', description: 'ประเมินกล้อง Sony มือสองตามรุ่น สภาพ อุปกรณ์ และความต้องการตลาด' },
        { name: 'กล้อง Fujifilm มือสอง', url: 'https://amphon.co.th/%E0%B8%9A%E0%B8%A3%E0%B8%B4%E0%B8%81%E0%B8%B2%E0%B8%A3/%E0%B8%A3%E0%B8%B1%E0%B8%9A%E0%B8%8B%E0%B8%B7%E0%B9%89%E0%B8%AD%E0%B8%81%E0%B8%A5%E0%B9%89%E0%B8%AD%E0%B8%87-fujifilm', description: 'ประเมินกล้อง Fujifilm มือสองตามรุ่น สภาพ อุปกรณ์ และความต้องการตลาด' },
        { name: 'กล้อง Nikon มือสอง', url: 'https://amphon.co.th/%E0%B8%9A%E0%B8%A3%E0%B8%B4%E0%B8%81%E0%B8%B2%E0%B8%A3/%E0%B8%A3%E0%B8%B1%E0%B8%9A%E0%B8%8B%E0%B8%B7%E0%B9%89%E0%B8%AD%E0%B8%81%E0%B8%A5%E0%B9%89%E0%B8%AD%E0%B8%87-nikon', description: 'ประเมินกล้อง Nikon มือสองตามรุ่น สภาพ อุปกรณ์ และความต้องการตลาด' },
        { name: 'เลนส์กล้องมือสอง', url: 'https://amphon.co.th/%E0%B8%9A%E0%B8%A3%E0%B8%B4%E0%B8%81%E0%B8%B2%E0%B8%A3/%E0%B8%A3%E0%B8%B1%E0%B8%9A%E0%B8%8B%E0%B8%B7%E0%B9%89%E0%B8%AD%E0%B9%80%E0%B8%A5%E0%B8%99%E0%B8%AA%E0%B9%8C%E0%B8%81%E0%B8%A5%E0%B9%89%E0%B8%AD%E0%B8%87', description: 'ประเมินเลนส์ตามเมาท์ ระยะ สภาพชิ้นเลนส์ ระบบโฟกัส และอุปกรณ์ที่มี' },
        { name: 'กล้อง Mirrorless มือสอง', url: 'https://amphon.co.th/%E0%B8%9A%E0%B8%A3%E0%B8%B4%E0%B8%81%E0%B8%B2%E0%B8%A3/%E0%B8%A3%E0%B8%B1%E0%B8%9A%E0%B8%8B%E0%B8%B7%E0%B9%89%E0%B8%AD%E0%B8%81%E0%B8%A5%E0%B9%89%E0%B8%AD%E0%B8%87-mirrorless', description: 'ประเมินกล้อง Mirrorless มือสองตามรุ่น สภาพ อุปกรณ์ และความต้องการตลาด' },
        { name: 'กล้องฟิล์มมือสอง', url: 'https://amphon.co.th/%E0%B8%9A%E0%B8%A3%E0%B8%B4%E0%B8%81%E0%B8%B2%E0%B8%A3/%E0%B8%A3%E0%B8%B1%E0%B8%9A%E0%B8%8B%E0%B8%B7%E0%B9%89%E0%B8%AD%E0%B8%81%E0%B8%A5%E0%B9%89%E0%B8%AD%E0%B8%87%E0%B8%9F%E0%B8%B4%E0%B8%A5%E0%B9%8C%E0%B8%A1', description: 'ประเมินกล้องฟิล์มตามรุ่น สภาพ อุปกรณ์ และการใช้งานจริง' },
        { name: 'GoPro และกล้อง Action Camera', url: 'https://amphon.co.th/%E0%B8%9A%E0%B8%A3%E0%B8%B4%E0%B8%81%E0%B8%B2%E0%B8%A3/%E0%B8%A3%E0%B8%B1%E0%B8%9A%E0%B8%8B%E0%B8%B7%E0%B9%89%E0%B8%AD-gopro-action-camera', description: 'ประเมินกล้อง Action Camera ตามรุ่น สภาพ อุปกรณ์เสริม และการใช้งานจริง' },
        { name: 'กล้องมีปัญหาและกล้องเสีย', url: 'https://amphon.co.th/%E0%B8%9A%E0%B8%A3%E0%B8%B4%E0%B8%81%E0%B8%B2%E0%B8%A3/%E0%B8%A3%E0%B8%B1%E0%B8%9A%E0%B8%8B%E0%B8%B7%E0%B9%89%E0%B8%AD%E0%B8%81%E0%B8%A5%E0%B9%89%E0%B8%AD%E0%B8%87%E0%B9%80%E0%B8%AA%E0%B8%B5%E0%B8%A2', description: 'ประเมินกล้องที่มีปัญหาตามอาการ สภาพ อุปกรณ์ และชิ้นส่วนที่ยังใช้งานได้' }
      ]
    });
  } else if (slug === 'รับซื้อคอมบริษัท') {
    offerCatalogSchema = createOfferCatalogSchema({
        name: 'รับซื้อคอมบริษัทและอุปกรณ์สำนักงาน',
        pageUrl,
        items: [
          { name: 'คอมสำนักงาน', url: '/บริการ/รับซื้อคอมสำนักงาน', description: 'รับซื้อคอมพิวเตอร์สำนักงาน พีซีออฟฟิศหลายเครื่อง' },
          { name: 'คอมยกล็อต', url: '/บริการ/รับซื้อคอมยกล็อต', description: 'รับซื้อคอมพิวเตอร์ยกล็อต จำนวนมาก ประเมินเหมา' },
          { name: 'โน๊ตบุ๊คบริษัท', url: '/บริการ/รับซื้อโน๊ตบุ๊คบริษัท', description: 'รับซื้อโน๊ตบุ๊คบริษัท โน๊ตบุ๊คพนักงานเก่า' },
          { name: 'สินค้าไอทีบริษัท', url: '/บริการ/รับซื้อสินค้าไอทีบริษัท', description: 'รับซื้อสินค้าไอทีองค์กร โทรศัพท์ แท็บเล็ตบริษัท' },
          { name: 'อุปกรณ์สำนักงานมือสอง', url: '/บริการ/รับซื้ออุปกรณ์สำนักงานมือสอง', description: 'รับซื้อจอคอม ปริ้นเตอร์ UPS เครื่องสแกนบาร์โค้ด' },
          { name: 'Server / Network', url: '/บริการ/รับซื้อ-server-network', description: 'รับซื้อเซิร์ฟเวอร์ NAS สวิตช์และอุปกรณ์เน็ตเวิร์ก' },
          { name: 'คอมบริษัทปิดกิจการ', url: '/บริการ/รับซื้อคอมบริษัทปิดกิจการ', description: 'รับซื้อคอมพิวเตอร์และทรัพย์สินไอทีจากบริษัทปิดกิจการ' },
          { name: 'ประมูลคอมพิวเตอร์มือสอง', url: '/บริการ/รับประมูลคอมพิวเตอร์มือสอง', description: 'รับประมูลคอมพิวเตอร์และอุปกรณ์ไอทีสำนักงาน' },
          { name: 'เคลียร์อุปกรณ์ไอที', url: '/บริการ/รับเคลียร์อุปกรณ์ไอทีสำนักงาน', description: 'รับเคลียร์อุปกรณ์ไอที ย้ายสำนักงาน โละเครื่องเก่า' }
        ]
      });
  }
}

const schemaExtras = [
  createServiceSchema({
    pageUrl,
    name: title,
    description,
    serviceType: mainKeyword,
    image: pageImage,
    offerCatalogId: offerCatalogSchema ? schemaIds.offerCatalog(pageUrl) : undefined,
  }),
  ...(offerCatalogSchema ? [offerCatalogSchema] : []),
  ...faqSchemaIfVisible(pageUrl, faqs),
];

const steps = [
  { n: 1, title: 'ส่งรูปสินค้า', desc: 'ส่งรูปและสเปกผ่าน Line @webuy' },
  { n: 2, title: 'ประเมินราคาฟรี', desc: 'รับราคาใน 15–30 นาที' },
  { n: 3, title: 'นัดรับ / เข้าร้าน', desc: 'นัดรับถึงที่ หรือมาที่ร้านอุบลฯ' },
  { n: 4, title: 'ตรวจสอบและจ่ายเงิน', desc: 'หลังตรวจสินค้าและตกลงราคาแล้ว โอนเงินทันที' },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={pageUrl}
  ogImage={ogImage}
  heroImage={heroImage}
  breadcrumbs={breadcrumbs}
  pageType="WebPage"
  mainEntityId={schemaIds.service(pageUrl)}
  dateModified={dateModified}
  schemaExtras={schemaExtras}
>
  <!-- Page hero -->
  <header class="page-header page-header--service">
    <div class="container page-header__grid">
      <div class="page-header__content">
        <span class="tag tag--orange page-header__tag">{mainKeyword ?? 'บริการรับซื้อ'}</span>
        <h1 class="page-header__title">{h1 || title}</h1>
        <p class="page-header__desc page-header__desc--clamp">{description}</p>
        <div class="page-header__cta page-header__cta--service">
          <a href={site.line} class="btn btn--line btn--lg page-header__cta-line" target="_blank" rel="noopener noreferrer">
            ส่งรูปประเมิน LINE
          </a>
          <a href={`tel:${site.phoneTel}`} class="btn btn--ghost btn--lg page-header__cta-phone">
            โทร {site.phone}
          </a>
        </div>
        <ul class="page-header__trust" aria-label="จุดเด่นของร้าน">
          <li>มีหน้าร้านจริงที่อุบลราชธานี</li>
          <li>ประเมินฟรี ไม่ผูกมัด</li>
          <li>ส่งรูปเช็กราคาเบื้องต้นได้ทั่วประเทศ</li>
        </ul>
      </div>
      {heroImage && (
        <figure class="page-header__figure">
          <OptimizedImage
            src={heroImage}
            alt={getImageAlt(heroImage, `${title} — อำพล เทรดดิ้ง`)}
            loading="eager"
            width={600}
            height={338}
            fetchpriority="high"
          />
        </figure>
      )}
    </div>
  </header>

  <div class="container service-mobile-tools">
    <ServiceQuickSummary items={quickSummary} />
    {intentChips.length > 0 && (
      <RelatedIntentChips services={intentChips} heading={intentChipHeading} />
    )}
  </div>

  <!-- Main content + sidebar -->
  <div class="container content-layout content-layout--service">
    <article class="prose prose--service">
      <Content />
      <div id="inline-service-cta-anchor" class="inline-service-cta-anchor" hidden>
        <InlineServiceCTA />
      </div>
    </article>

    <aside class="sidebar sidebar--service">
      <div class="sidebar__box">
        <p class="sidebar__title">ติดต่อประเมินราคา</p>
        <div style="display:flex;flex-direction:column;gap:.625rem;">
          <a href={site.line} class="btn btn--line btn--sm" target="_blank" rel="noopener noreferrer">
            แชท Line @webuy
          </a>
          <a href={`tel:${site.phoneTel}`} class="btn btn--phone btn--sm">
            โทร {site.phone}
          </a>
        </div>
      </div>

      {otherServices.length > 0 && (
        <div class="sidebar__box">
          <p class="sidebar__title">บริการที่เกี่ยวข้อง</p>
          <ul class="sidebar__links">
            {otherServices.map((service) => (
              <li>
                <a href={`/บริการ/${service.data.slug}`}>
                  {sanitizeServiceDisplayText(service.data.title)}
                </a>
              </li>
            ))}
          </ul>
          <p style="margin-top:.875rem;margin-bottom:0;">
            <a href="/รับซื้อสินค้าไอที" class="sidebar__view-all">ดูบริการทั้งหมด →</a>
          </p>
        </div>
      )}

      {relatedAreas.length > 0 && (
        <div class="sidebar__box">
          <p class="sidebar__title">พื้นที่ให้บริการ</p>
          <ul class="sidebar__links">
            {relatedAreas.map((area) => (
              <li>
                <a href={`/รับซื้อ/${area.data.slug}`}>{area.data.title}</a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </aside>
  </div>

  <!-- Steps -->
  <section class="section section--gray">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">ขั้นตอน</span>
        <h2>ขายง่าย ใน 4 ขั้นตอน</h2>
      </div>
      <div class="steps">
        {steps.map((s) => (
          <div class="step">
            <span class="step__number">{s.n}</span>
            <h3 class="step__title">{s.title}</h3>
            <p class="step__desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faqs} />

  <Reviews />

  <CTAContact title={`${title} — นัดประเมินราคาฟรีวันนี้`} />

  {relatedCards.length > 0 && (
    <section class="section section--related-services">
      <div class="container">
        <div class="section-header section-header--left">
          <span class="eyebrow">บริการที่เกี่ยวข้อง</span>
          <h2>บริการรับซื้ออื่นที่เกี่ยวข้อง</h2>
        </div>
        <div class="grid grid--3 related-services__grid">
          {relatedCards.map((service) => (
            <div class="related-services__item">
              <ServiceCard
                title={sanitizeServiceDisplayText(service.data.title)}
                description={sanitizeServiceDisplayText(service.data.description)}
                href={`/บริการ/${service.data.slug}`}
                keyword={service.data.mainKeyword}
                image={serviceThumbnails[service.data.slug]}
                compact
              />
            </div>
          ))}
        </div>
        <p class="related-services__more">
          <a href="/รับซื้อสินค้าไอที" class="btn btn--outline btn--sm">ดูบริการทั้งหมด →</a>
        </p>
      </div>
    </section>
  )}
</BaseLayout>

<script>
  function placeInlineCta() {
    const prose = document.querySelector('article.prose--service');
    const anchor = document.getElementById('inline-service-cta-anchor');
    if (!prose || !anchor) return;

    const h2s = prose.querySelectorAll(':scope > h2');
    let insertBefore: Element | null = null;

    if (h2s.length >= 2) {
      insertBefore = h2s[1];
    } else {
      const children = [...prose.children].filter((el) => el !== anchor);
      const insertAt = Math.max(1, Math.floor(children.length * 0.4));
      insertBefore = children[insertAt] ?? null;
    }

    anchor.hidden = false;
    if (insertBefore) {
      insertBefore.before(anchor);
    }
  }

  function wrapProseTables() {
    const prose = document.querySelector('article.prose--service');
    if (!prose) return;
    prose.querySelectorAll('table').forEach((table) => {
      if (table.parentElement?.classList.contains('table-scroll')) return;
      const wrap = document.createElement('div');
      wrap.className = 'table-scroll';
      wrap.setAttribute('role', 'region');
      wrap.setAttribute('aria-label', 'ตารางข้อมูล เลื่อนซ้ายขวาได้');
      table.parentNode?.insertBefore(wrap, table);
      wrap.appendChild(table);
    });
  }

  placeInlineCta();
  wrapProseTables();

  document.querySelectorAll('.prose--service img:not([loading])').forEach((img) => {
    (img as HTMLImageElement).loading = 'lazy';
  });
</script>
