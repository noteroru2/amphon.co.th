---
import BaseLayout from './BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { getImageAlt, serviceThumbnails } from '../config/images';
import CTAContact from '../components/CTAContact.astro';
import FAQ from '../components/FAQ.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Reviews from '../components/Reviews.astro';
import {
  absoluteUrl,
  schemaIds,
  createServiceSchema,
  contentDateModified,
  faqSchemaIfVisible,
  resolveOgImage,
} from '../lib/seo';
import { site } from '../config/site';
import { sanitizeServiceDisplayText } from '../config/service-clusters';
import type { BreadcrumbItem } from '../config/site';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'services'>;
  relatedAreas?: CollectionEntry<'serviceAreas'>[];
  otherServices?: CollectionEntry<'services'>[];
}

const { entry, relatedAreas = [], otherServices = [] } = Astro.props;
const { title, h1, description, slug, faqs, mainKeyword, relatedKeywords, ogImage, heroImage, date, updated } =
  entry.data;
const { Content } = await render(entry);

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'บริการ', href: '/รับซื้อสินค้าไอที' },
  { label: title },
];

const pageUrl = absoluteUrl(`/บริการ/${slug}`);
const pageImage = resolveOgImage(ogImage, heroImage);
const dateModified = contentDateModified(date, updated);

const schemaExtras = [
  createServiceSchema({
    pageUrl,
    name: title,
    description,
    serviceType: mainKeyword,
    image: pageImage,
  }),
  ...faqSchemaIfVisible(pageUrl, faqs),
];

if (slug === 'รับซื้อคอมพิวเตอร์' || slug === 'รับซื้อ-macbook' || slug === 'รับซื้อ-ipad' || slug === 'รับซื้อ-iphone' || slug === 'รับซื้อกล้อง' || slug === 'รับซื้อคอมบริษัท') {
  const { createOfferCatalogSchema } = await import('../lib/seo');
  
  if (slug === 'รับซื้อคอมพิวเตอร์') {
    schemaExtras.push(
      createOfferCatalogSchema({
        pageUrl,
        name: 'รับซื้อคอมพิวเตอร์และอุปกรณ์ไอที',
        items: [
          { name: 'คอมสำนักงาน', url: '/บริการ/รับซื้อคอมสำนักงาน', description: 'รับซื้อคอมสำนักงาน เครื่องแบรนด์เนมทั่วไป' },
          { name: 'คอมประกอบ', url: '/บริการ/รับซื้อคอมประกอบ', description: 'รับซื้อคอมประกอบ Custom PC แยกชิ้น' },
          { name: 'Gaming PC', url: '/บริการ/รับซื้อ-gaming-pc', description: 'รับซื้อคอมเล่นเกม สเปกสูง' },
          { name: 'คอมบริษัท/ยกล็อต', url: '/บริการ/รับซื้อคอมบริษัท', description: 'รับซื้อคอมพิวเตอร์องค์กร ประมูลยกล็อต' },
          { name: 'คอมเสีย/ซากคอม', url: '/บริการ/รับซื้อคอมเสีย', description: 'รับซื้อซากคอม เปิดไม่ติด ตีราคาเป็นอะไหล่' },
          { name: 'อุปกรณ์คอมแยกชิ้น', url: '/บริการ/รับซื้อการ์ดจอ', description: 'รับซื้ออะไหล่คอมพิวเตอร์ เช่น การ์ดจอ CPU RAM' }
        ]
      })
    );
  } else if (slug === 'รับซื้อ-macbook') {
    schemaExtras.push(
      createOfferCatalogSchema({
        pageUrl,
        name: 'รับซื้อ MacBook มือสอง ทุกรุ่น',
        items: [
          { name: 'MacBook Air', url: '/บริการ/รับซื้อ-macbook-air', description: 'รับซื้อ MacBook Air ชิป M1, M2, M3, M4' },
          { name: 'MacBook Pro', url: '/บริการ/รับซื้อ-macbook-pro', description: 'รับซื้อ MacBook Pro สายตัดต่อ สเปกสูง' },
          { name: 'MacBook M1/M2', url: '/บริการ/รับซื้อ-macbook-m1', description: 'รับซื้อ MacBook ชิป M1 และ M2 ทุกรุ่น' },
          { name: 'MacBook M3/M4', url: '/บริการ/รับซื้อ-macbook-m3-m4', description: 'รับซื้อ MacBook ชิปใหม่ล่าสุด M3 และ M4' },
          { name: 'Intel MacBook', url: '/บริการ/รับซื้อ-macbook-intel', description: 'รับซื้อ MacBook Intel รุ่นเก่าปี 2018-2020' },
          { name: 'MacBook เสีย/จอแตก', url: '/บริการ/รับซื้อ-macbook-เสีย', description: 'รับซื้อซาก MacBook เสีย เปิดไม่ติด จอแตก' },
          { name: 'iMac/Mac mini', url: '/บริการ/รับซื้อ-imac-mac-mini', description: 'รับซื้อคอมพิวเตอร์ตั้งโต๊ะ iMac และ Mac mini' }
        ]
      })
    );
  } else if (slug === 'รับซื้อ-ipad') {
    schemaExtras.push(
      createOfferCatalogSchema({
        pageUrl,
        name: 'รับซื้อ iPad มือสอง ทุกรุ่น',
        items: [
          { name: 'iPad Pro', url: '/บริการ/รับซื้อ-ipad-pro', description: 'รับซื้อ iPad Pro M1, M2, M4 ทุกความจุ' },
          { name: 'iPad Air', url: '/บริการ/รับซื้อ-ipad-air', description: 'รับซื้อ iPad Air 4, 5, M2, M3' },
          { name: 'iPad mini', url: '/บริการ/รับซื้อ-ipad-mini', description: 'รับซื้อ iPad mini 6, A17 Pro' },
          { name: 'iPad Gen', url: '/บริการ/รับซื้อ-ipad-gen', description: 'รับซื้อ iPad Gen 8, 9, 10' },
          { name: 'iPad เสีย/จอแตก', url: '/บริการ/รับซื้อ-ipad-เสีย', description: 'รับซื้อซาก iPad เสีย เปิดไม่ติด จอแตก' },
          { name: 'Apple Pencil', url: '/บริการ/รับซื้อ-apple-pencil', description: 'รับซื้อ Apple Pencil Gen 1, Gen 2, USB-C, Pro' },
          { name: 'Magic Keyboard iPad', url: '/บริการ/รับซื้อ-magic-keyboard-ipad', description: 'รับซื้อ Magic Keyboard และ Smart Keyboard' }
        ]
      })
    );
  } else if (slug === 'รับซื้อ-iphone') {
    schemaExtras.push(
      createOfferCatalogSchema({
        pageUrl,
        name: 'รับซื้อ iPhone มือสอง ทุกรุ่น',
        items: [
          { name: 'iPhone 17', url: '/บริการ/รับซื้อ-iphone-17', description: 'รับซื้อ iPhone 17 ทุกรุ่น ทุกความจุ' },
          { name: 'iPhone Pro Max', url: '/บริการ/รับซื้อ-iphone-pro-max', description: 'รับซื้อ iPhone Pro Max ทุกซีรีส์ ราคาสูง' },
          { name: 'iPhone 16', url: '/บริการ/รับซื้อ-iphone-16', description: 'รับซื้อ iPhone 16, 16 Pro, 16 Pro Max' },
          { name: 'iPhone 15', url: '/บริการ/รับซื้อ-iphone-15', description: 'รับซื้อ iPhone 15, 15 Pro, 15 Pro Max' },
          { name: 'iPhone 14', url: '/บริการ/รับซื้อ-iphone-14', description: 'รับซื้อ iPhone 14, 14 Pro, 14 Pro Max' },
          { name: 'iPhone 13', url: '/บริการ/รับซื้อ-iphone-13', description: 'รับซื้อ iPhone 13, 13 Pro, 13 Pro Max' },
          { name: 'iPhone จอแตก', url: '/บริการ/รับซื้อ-iphone-จอแตก', description: 'รับซื้อ iPhone จอแตก จอเป็นเส้น ทัชไม่ติด' },
          { name: 'iPhone Face ID เสีย', url: '/บริการ/รับซื้อ-iphone-face-id-เสีย', description: 'รับซื้อ iPhone สแกนหน้าไม่ได้' },
          { name: 'iPhone ติด iCloud', url: '/บริการ/รับซื้อ-iphone-ติด-icloud', description: 'รับซื้อ iPhone ติดล็อค ตามเงื่อนไข' },
          { name: 'iPhone เครื่องนอก', url: '/บริการ/รับซื้อ-iphone-เครื่องนอก', description: 'รับซื้อ iPhone โมเดลนอก ติดซิมล็อค' }
        ]
      })
    );
  } else if (slug === 'รับซื้อกล้อง') {
    schemaExtras.push({
      '@type': 'OfferCatalog',
      '@id': `${pageUrl}#offercatalog`,
      name: 'รับซื้อกล้องมือสอง ทุกประเภท',
      inLanguage: 'th-TH',
      itemListElement: [
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'กล้อง Canon',
            description: 'รับซื้อกล้อง Canon DSLR, Mirrorless EOS R Series',
            url: '/บริการ/รับซื้อกล้อง-canon',
            inLanguage: 'th-TH',
            provider: { '@id': `${Astro.site}#localbusiness` }
          }
        },
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'กล้อง Sony',
            description: 'รับซื้อกล้อง Sony Alpha, A7 Series',
            url: '/บริการ/รับซื้อกล้อง-sony',
            inLanguage: 'th-TH',
            provider: { '@id': `${Astro.site}#localbusiness` }
          }
        },
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'กล้อง Fujifilm',
            description: 'รับซื้อกล้อง Fujifilm X-Series, GFX',
            url: '/บริการ/รับซื้อกล้อง-fujifilm',
            inLanguage: 'th-TH',
            provider: { '@id': `${Astro.site}#localbusiness` }
          }
        },
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'กล้อง Nikon',
            description: 'รับซื้อกล้อง Nikon Z Series, DSLR',
            url: '/บริการ/รับซื้อกล้อง-nikon',
            inLanguage: 'th-TH',
            provider: { '@id': `${Astro.site}#localbusiness` }
          }
        },
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'เลนส์กล้อง',
            description: 'รับซื้อเลนส์กล้องมือสอง ทุกแบรนด์',
            url: '/บริการ/รับซื้อเลนส์กล้อง',
            inLanguage: 'th-TH',
            provider: { '@id': `${Astro.site}#localbusiness` }
          }
        },
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'กล้อง Mirrorless',
            description: 'รับซื้อกล้อง Mirrorless Full Frame, APS-C',
            url: '/บริการ/รับซื้อกล้อง-mirrorless',
            inLanguage: 'th-TH',
            provider: { '@id': `${Astro.site}#localbusiness` }
          }
        },
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'กล้องฟิล์ม',
            description: 'รับซื้อกล้องฟิล์ม เลนส์มือหมุน วินเทจ',
            url: '/บริการ/รับซื้อกล้องฟิล์ม',
            inLanguage: 'th-TH',
            provider: { '@id': `${Astro.site}#localbusiness` }
          }
        },
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'GoPro / Action Camera',
            description: 'รับซื้อกล้อง GoPro, DJI Action, Insta360',
            url: '/บริการ/รับซื้อ-gopro-action-camera',
            inLanguage: 'th-TH',
            provider: { '@id': `${Astro.site}#localbusiness` }
          }
        },
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'กล้องเสีย',
            description: 'รับซื้อกล้องเปิดไม่ติด จอแตก เลนส์รา ฝ้า',
            url: '/บริการ/รับซื้อกล้องเสีย',
            inLanguage: 'th-TH',
            provider: { '@id': `${Astro.site}#localbusiness` }
          }
        }
      ]
    });
  } else if (slug === 'รับซื้อคอมบริษัท') {
    schemaExtras.push(
      createOfferCatalogSchema({
        name: 'รับซื้อคอมบริษัทและอุปกรณ์สำนักงาน',
        pageUrl,
        items: [
          { name: 'คอมสำนักงาน', url: '/บริการ/รับซื้อคอมสำนักงาน', description: 'รับซื้อคอมพิวเตอร์สำนักงาน พีซีออฟฟิศหลายเครื่อง' },
          { name: 'คอมยกล็อต', url: '/บริการ/รับซื้อคอมยกล็อต', description: 'รับซื้อคอมพิวเตอร์ยกล็อต จำนวนมาก ประเมินเหมา' },
          { name: 'โน๊ตบุ๊คบริษัท', url: '/บริการ/รับซื้อโน๊ตบุ๊คบริษัท', description: 'รับซื้อโน๊ตบุ๊คบริษัท โน๊ตบุ๊คพนักงานเก่า' },
          { name: 'สินค้าไอทีบริษัท', url: '/บริการ/รับซื้อสินค้าไอทีบริษัท', description: 'รับซื้อสินค้าไอทีองค์กร โทรศัพท์ แท็บเล็ตบริษัท' },
          { name: 'อุปกรณ์สำนักงานมือสอง', url: '/บริการ/รับซื้ออุปกรณ์สำนักงานมือสอง', description: 'รับซื้อจอคอม ปริ้นเตอร์ UPS เครื่องสแกนบาร์โค้ด' },
          { name: 'Server / Network', url: '/บริการ/รับซื้อ-server-network', description: 'รับซื้อเซิร์ฟเวอร์ NAS สวิตช์และอุปกรณ์เน็ตเวิร์ก' },
          { name: 'คอมบริษัทปิดกิจการ', url: '/บริการ/รับซื้อคอมบริษัทปิดกิจการ', description: 'รับซื้อคอมพิวเตอร์และทรัพย์สินไอทีจากบริษัทปิดกิจการ' },
          { name: 'ประมูลคอมพิวเตอร์มือสอง', url: '/บริการ/รับประมูลคอมพิวเตอร์มือสอง', description: 'รับประมูลคอมพิวเตอร์และอุปกรณ์ไอทีสำนักงาน' },
          { name: 'เคลียร์อุปกรณ์ไอที', url: '/บริการ/รับเคลียร์อุปกรณ์ไอทีสำนักงาน', description: 'รับเคลียร์อุปกรณ์ไอที ย้ายสำนักงาน โละเครื่องเก่า' }
        ]
      })
    );
  }
}

const steps = [
  { n: 1, title: 'ส่งรูปสินค้า', desc: 'ส่งรูปและสเปกผ่าน Line @webuy' },
  { n: 2, title: 'ประเมินราคาฟรี', desc: 'รับราคาใน 15–30 นาที' },
  { n: 3, title: 'นัดรับ / เข้าร้าน', desc: 'นัดรับถึงที่ หรือมาที่ร้านอุบลฯ' },
  { n: 4, title: 'ตรวจสอบและจ่ายเงิน', desc: 'จ่ายทันที เงินสด / โอน' },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={pageUrl}
  ogImage={ogImage}
  heroImage={heroImage}
  breadcrumbs={breadcrumbs}
  pageType="WebPage"
  mainEntityId={schemaIds.service(pageUrl)}
  dateModified={dateModified}
  schemaExtras={schemaExtras}
>
  <!-- Page hero -->
  <header class="page-header">
    <div class="container page-header__grid">
      <div>
        <span class="tag tag--orange" style="margin-bottom:.875rem;">{mainKeyword ?? 'บริการรับซื้อ'}</span>
        <h1>{h1 || title}</h1>
        <p class="page-header__desc">{description}</p>
        <div class="page-header__cta">
          <a href={site.line} class="btn btn--line" target="_blank" rel="noopener noreferrer">
            แชท Line ประเมินราคา
          </a>
          <a href={`tel:${site.phoneTel}`} class="btn btn--ghost">
            โทร {site.phone}
          </a>
        </div>
      </div>
      {heroImage && (
        <figure class="page-header__figure">
          <OptimizedImage
            src={heroImage}
            alt={getImageAlt(heroImage, `${title} — อำพล เทรดดิ้ง ภาคอีสาน`)}
            loading="eager"
            width={600}
            height={338}
          />
        </figure>
      )}
    </div>
  </header>

  <!-- Main content + sidebar -->
  <div class="container content-layout">
    <article class="prose">
      <Content />
    </article>

    <aside class="sidebar">
      <div class="sidebar__box">
        <p class="sidebar__title">ติดต่อประเมินราคา</p>
        <div style="display:flex;flex-direction:column;gap:.625rem;">
          <a href={site.line} class="btn btn--line btn--sm" target="_blank" rel="noopener noreferrer">
            แชท Line @webuy
          </a>
          <a href={`tel:${site.phoneTel}`} class="btn btn--phone btn--sm">
            โทร {site.phone}
          </a>
        </div>
      </div>

      {otherServices.length > 0 && (
        <div class="sidebar__box">
          <p class="sidebar__title">บริการที่เกี่ยวข้อง</p>
          <ul class="sidebar__links">
            {otherServices.map((service) => (
              <li>
                <a href={`/บริการ/${service.data.slug}`}>
                  {sanitizeServiceDisplayText(service.data.title)}
                </a>
              </li>
            ))}
          </ul>
          <p style="margin-top:.875rem;margin-bottom:0;">
            <a href="/รับซื้อสินค้าไอที" class="sidebar__view-all">ดูบริการทั้งหมด →</a>
          </p>
        </div>
      )}

      {relatedAreas.length > 0 && (
        <div class="sidebar__box">
          <p class="sidebar__title">พื้นที่ให้บริการ</p>
          <ul class="sidebar__links">
            {relatedAreas.map((area) => (
              <li>
                <a href={`/รับซื้อ/${area.data.slug}`}>{area.data.title}</a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </aside>
  </div>

  <!-- Steps -->
  <section class="section section--gray">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">ขั้นตอน</span>
        <h2>ขายง่าย ใน 4 ขั้นตอน</h2>
      </div>
      <div class="steps">
        {steps.map((s) => (
          <div class="step">
            <span class="step__number">{s.n}</span>
            <h3 class="step__title">{s.title}</h3>
            <p class="step__desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faqs} />

  <Reviews />

  <CTAContact title={`${title} — นัดประเมินราคาฟรีวันนี้`} />

  {otherServices.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header section-header--left">
          <span class="eyebrow">บริการที่เกี่ยวข้อง</span>
          <h2>บริการรับซื้ออื่นที่เกี่ยวข้อง</h2>
        </div>
        <div class="grid grid--3">
          {otherServices.slice(0, 3).map((service) => (
            <ServiceCard
              title={sanitizeServiceDisplayText(service.data.title)}
              description={sanitizeServiceDisplayText(service.data.description)}
              href={`/บริการ/${service.data.slug}`}
              keyword={service.data.mainKeyword}
              image={serviceThumbnails[service.data.slug]}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
