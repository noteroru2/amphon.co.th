---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { site } from '../config/site';
import { absoluteUrl, seoTitle, buildPageGraph, resolveOgImage } from '../lib/seo';
import '@fontsource/sarabun/400.css';
import '@fontsource/sarabun/500.css';
import '@fontsource/sarabun/600.css';
import '@fontsource/sarabun/700.css';
import '@fontsource/sarabun/800.css';
import type { BreadcrumbItem } from '../config/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  heroImage?: string;
  breadcrumbs?: BreadcrumbItem[];
  pageType?: string;
  datePublished?: string;
  dateModified?: string;
  mainEntityId?: string;
  schemaExtras?: Record<string, unknown>[];
  noindex?: boolean;
  geoPlace?: string;
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  ogImage,
  heroImage,
  breadcrumbs = [],
  pageType = 'WebPage',
  datePublished,
  dateModified,
  mainEntityId,
  schemaExtras = [],
  noindex = false,
  geoPlace,
} = Astro.props;

const pageTitle = seoTitle(title);
const canonicalUrl = canonical ?? absoluteUrl(Astro.url.pathname);
const ogImageUrl = resolveOgImage(ogImage, heroImage);

const schemaGraph = buildPageGraph({
  pageUrl: canonicalUrl,
  name: title,
  description,
  pageType,
  breadcrumbs,
  datePublished,
  dateModified,
  mainEntityId,
  primaryImageUrl: ogImageUrl,
  extra: schemaExtras,
});
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <meta
      name="robots"
      content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Geo -->
    {geoPlace && (
      <meta name="geo.placename" content={geoPlace} />
    )}
    <meta name="geo.region" content={site.geo.region} />
    <meta name="geo.position" content={`${site.geo.latitude};${site.geo.longitude}`} />
    <meta name="ICBM" content={`${site.geo.latitude}, ${site.geo.longitude}`} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:locale" content={site.locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </head>

  <body>
    <Header />

    {breadcrumbs.length > 1 && (
      <div class="breadcrumbs-wrap">
        <div class="container">
          <Breadcrumbs items={breadcrumbs} />
        </div>
      </div>
    )}

    <main id="main">
      <slot />
    </main>

    <Footer />
    <StickyCTA />
  </body>
</html>

<style is:global>
  .breadcrumbs-wrap {
    background: var(--color-dark);
    border-bottom: 1px solid rgba(255 255 255 / 0.08);
  }
</style>
