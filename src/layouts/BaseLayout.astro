---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { site } from '../config/site';
import { absoluteUrl, seoTitle, buildPageGraph, resolveOgImage } from '../lib/seo';
import type { BreadcrumbItem } from '../config/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  heroImage?: string;
  breadcrumbs?: BreadcrumbItem[];
  pageType?: string;
  datePublished?: string;
  dateModified?: string;
  mainEntityId?: string;
  schemaExtras?: Record<string, unknown>[];
  noindex?: boolean;
  geoPlace?: string;
  containedBreadcrumbs?: boolean;
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  ogImage,
  heroImage,
  breadcrumbs = [],
  pageType = 'WebPage',
  datePublished,
  dateModified,
  mainEntityId,
  schemaExtras = [],
  noindex = false,
  geoPlace,
  containedBreadcrumbs = false,
} = Astro.props;

const pageTitle = seoTitle(title);
const canonicalUrl = canonical ?? absoluteUrl(Astro.url.pathname);
const ogImageUrl = resolveOgImage(ogImage, heroImage);

const schemaGraph = buildPageGraph({
  pageUrl: canonicalUrl,
  name: title,
  description,
  pageType,
  breadcrumbs,
  datePublished,
  dateModified,
  mainEntityId,
  primaryImageUrl: ogImageUrl,
  extra: schemaExtras,
});
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <meta
      name="robots"
      content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Geo -->
    {geoPlace && (
      <meta name="geo.placename" content={geoPlace} />
    )}
    <meta name="geo.region" content={site.geo.region} />
    <meta name="geo.position" content={`${site.geo.latitude};${site.geo.longitude}`} />
    <meta name="ICBM" content={`${site.geo.latitude}, ${site.geo.longitude}`} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:locale" content={site.locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </head>

  <body>
    <Header />

    {breadcrumbs.length > 1 && (
      <div class:list={['breadcrumbs-wrap', containedBreadcrumbs && 'breadcrumbs-wrap--contained']}>
        <div class="container">
          <Breadcrumbs items={breadcrumbs} />
        </div>
      </div>
    )}

    <main id="main">
      <slot />
    </main>

    <Footer />
    <StickyCTA />
  </body>
</html>

<script>
  function wrapProseTables() {
    document.querySelectorAll('.prose table').forEach((table) => {
      if (table.parentElement?.classList.contains('table-scroll')) return;
      const wrap = document.createElement('div');
      wrap.className = 'table-scroll';
      wrap.setAttribute('role', 'region');
      wrap.setAttribute('aria-label', 'ตารางข้อมูล เลื่อนซ้ายขวาได้');
      table.parentNode?.insertBefore(wrap, table);
      wrap.appendChild(table);
    });
  }

  function initProseTables() {
    wrapProseTables();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProseTables);
  } else {
    initProseTables();
  }
</script>

<style is:global>
  .breadcrumbs-wrap {
    background: var(--color-dark);
    border-bottom: 1px solid rgba(255 255 255 / 0.08);
    padding-block: 0.75rem;
    --breadcrumbs-color: rgba(255 255 255 / 0.7);
    --breadcrumbs-separator: rgba(255 255 255 / 0.35);
    --breadcrumbs-current: #ffffff;
    --breadcrumbs-hover: var(--color-primary);
  }

  .breadcrumbs-wrap .breadcrumbs {
    margin-bottom: 0;
  }

  .breadcrumbs-wrap--contained {
    background: transparent;
    border-bottom: 0;
    padding-top: 0.75rem;
    --breadcrumbs-color: rgba(15 23 42 / 0.62);
    --breadcrumbs-separator: rgba(15 23 42 / 0.28);
    --breadcrumbs-current: var(--color-dark);
    --breadcrumbs-hover: var(--color-primary);
    --breadcrumbs-margin-bottom: 0;
  }

  .breadcrumbs-wrap--contained .container {
    background: transparent;
    border: 0;
    border-radius: 0;
    padding: 0 1.5rem 0.625rem;
    box-shadow: none;
  }

  .breadcrumbs-wrap--contained .breadcrumbs {
    display: inline-flex;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(15 23 42 / 0.04), rgba(15 23 42 / 0.07));
    border: 1px solid rgba(15 23 42 / 0.08);
  }

  @media (max-width: 767px) {
    .breadcrumbs-wrap--contained {
      padding-top: 0.5rem;
    }
    .breadcrumbs-wrap--contained .container {
      padding: 0 1.25rem 0.5rem;
    }
    .breadcrumbs-wrap--contained .breadcrumbs {
      padding: 0.45rem 0.8rem;
    }
  }
</style>
