---
import type { BreadcrumbItem } from '../config/site';

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol class="breadcrumbs__list">
    {items.map((item, index) => (
      <li class="breadcrumbs__item">
        {item.href && index < items.length - 1 ? (
          <a href={item.href}>{item.label}</a>
        ) : (
          <span aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs {
    margin-bottom: var(--breadcrumbs-margin-bottom, 1rem);
  }

  .breadcrumbs__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.875rem;
    color: var(--breadcrumbs-color, rgba(255, 255, 255, 0.7));
  }

  .breadcrumbs__item:not(:last-child)::after {
    content: '/';
    margin-left: 0.35rem;
    color: var(--breadcrumbs-separator, rgba(255, 255, 255, 0.35));
  }

  .breadcrumbs__item a {
    color: var(--breadcrumbs-color, rgba(255, 255, 255, 0.7));
    text-decoration: none;
    transition: color var(--transition, 0.18s ease);
  }

  .breadcrumbs__item a:hover {
    color: var(--breadcrumbs-hover, var(--color-primary, #f97316));
  }

  .breadcrumbs__item span {
    color: var(--breadcrumbs-current, #ffffff);
    font-weight: 500;
  }
</style>
