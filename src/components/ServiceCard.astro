---
import OptimizedImage from './OptimizedImage.astro';
import { getImageAlt } from '../config/images';

interface Props {
  title: string;
  description: string;
  href: string;
  keyword?: string;
  image?: string;
}

const { title, description, href, keyword, image } = Astro.props;
const alt = image ? getImageAlt(image, `${title} — อำพล เทรดดิ้ง`) : '';
---

<article class="card service-card">
  {image ? (
    <a href={href} tabindex="-1" aria-hidden="true">
      <OptimizedImage src={image} alt={alt} class="service-card__thumb" loading="lazy" width={400} height={225} />
    </a>
  ) : (
    <div class="card__icon" aria-hidden="true">📦</div>
  )}
  {keyword && <span class="tag tag--orange">{keyword}</span>}
  <h3 class="card__title">
    <a href={href}>{title}</a>
  </h3>
  <p class="card__desc">{description}</p>
  <a href={href} class="btn btn--outline btn--sm service-card__btn">
    ดูรายละเอียด →
  </a>
</article>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .service-card .tag {
    margin-bottom: 0.75rem;
    align-self: flex-start;
  }

  .service-card__btn {
    margin-top: auto;
    align-self: flex-start;
  }
</style>
