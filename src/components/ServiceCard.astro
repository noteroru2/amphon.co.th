---
import OptimizedImage from './OptimizedImage.astro';
import { getImageAlt } from '../config/images';

interface Props {
  title: string;
  description: string;
  href: string;
  keyword?: string;
  image?: string;
  imageAlt?: string;
  compact?: boolean;
}

const { title, description, href, keyword, image, imageAlt, compact = false } = Astro.props;
const alt = imageAlt ?? (image ? getImageAlt(image, `${title} — อำพล เทรดดิ้ง`) : '');
---

<article class:list={['card', 'service-card', { 'service-card--compact': compact }]}>
  {image ? (
    <a href={href} tabindex="-1" aria-hidden="true">
      <OptimizedImage src={image} alt={alt} class="service-card__thumb" loading="lazy" width={400} height={225} />
    </a>
  ) : (
    <div class="card__icon" aria-hidden="true">📦</div>
  )}
  {keyword && <span class="tag tag--orange">{keyword}</span>}
  <h3 class="card__title">
    <a href={href}>{title}</a>
  </h3>
  <p class="card__desc">{description}</p>
  <a href={href} class="btn btn--outline btn--sm service-card__btn">
    ดูรายละเอียด →
  </a>
</article>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .service-card .tag {
    margin-bottom: 0.75rem;
    align-self: flex-start;
  }

  .service-card__btn {
    margin-top: auto;
    align-self: flex-start;
  }

  .service-card--compact .tag {
    margin-bottom: 0.5rem;
    font-size: 0.6875rem;
  }

  .service-card--compact .card__title {
    font-size: 1rem;
    margin-bottom: 0.375rem;
  }

  .service-card--compact .card__desc {
    font-size: 0.875rem;
    margin-bottom: 0.875rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .service-card--compact :global(.service-card__thumb) {
    margin-bottom: 0.75rem;
    border-radius: 12px;
  }
</style>
