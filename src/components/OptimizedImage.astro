---
import { getImageAlt } from '../config/images';

interface Props {
  src: string;
  alt?: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'auto' | 'low';
  class?: string;
  sizes?: string;
  style?: string;
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  fetchpriority,
  class: className,
  sizes,
  style,
} = Astro.props;

const resolvedAlt = alt ?? getImageAlt(src, '');

// Auto-generate sizes if not provided but width is known
const resolvedSizes = sizes ?? (width ? `(max-width: 640px) 100vw, ${width}px` : undefined);
---

<img
  src={src}
  alt={resolvedAlt}
  width={width}
  height={height}
  loading={loading}
  decoding="async"
  class={className}
  sizes={resolvedSizes}
  style={style}
  {...(fetchpriority ? { fetchpriority } : {})}
/>
