---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
}

const { items, title = 'คำถามที่พบบ่อย' } = Astro.props;
---

{items.length > 0 && (
  <section class="faq section section--gray">
    <div class="container">
      <div class="section-header section-header--left">
        <span class="eyebrow">FAQ</span>
        <h2 class="section__title">{title}</h2>
      </div>
      <dl class="faq__list">
        {items.map((item) => (
          <>
            <dt class="faq__question">{item.question}</dt>
            <dd class="faq__answer">{item.answer}</dd>
          </>
        ))}
      </dl>
    </div>
  </section>
)}
