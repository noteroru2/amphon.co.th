---
import { site } from '../config/site';

interface Props {
  text?: string;
}

const {
  text = 'มีรูปสินค้าหรือสเปกแล้ว ส่งมาทาง LINE @webuy เพื่อเช็กราคาเบื้องต้นได้ฟรี ไม่ผูกมัดว่าต้องขาย',
} = Astro.props;
---

<aside class="inline-service-cta" data-inline-cta>
  <p class="inline-service-cta__text">{text}</p>
  <a
    href={site.line}
    class="btn btn--line btn--sm inline-service-cta__btn"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="ส่งรูปประเมินราคาทาง Line @webuy"
  >
    <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2C6.48 2 2 5.92 2 10.72c0 3.46 2.19 6.49 5.49 8.14-.19.68-.72 2.47-.83 2.86-.12.44.16.43.34.31.14-.09 2.26-1.52 3.17-2.14.59.09 1.2.13 1.83.13 5.52 0 10-3.92 10-8.72S17.52 2 12 2z"/>
    </svg>
    ส่งรูป LINE @webuy
  </a>
</aside>
