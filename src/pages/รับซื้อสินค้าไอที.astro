---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAContact from '../components/CTAContact.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getCollection } from 'astro:content';
import { absoluteUrl, schemaIds, createItemListSchema } from '../lib/seo';
import { serviceThumbnails } from '../config/images';
import { site } from '../config/site';

const services = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const breadcrumbs = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'บริการรับซื้อสินค้าไอที' },
];
const pageUrl = absoluteUrl('/รับซื้อสินค้าไอที');

const schemaExtras = [
  createItemListSchema({
    pageUrl,
    name: 'บริการรับซื้อสินค้าไอทีทั้งหมด',
    items: services.map((s) => ({
      name: s.data.title,
      url: absoluteUrl(`/บริการ/${s.data.slug}`),
      description: s.data.description,
    })),
  }),
];

const serviceHubGroups = [
  {
    title: 'Notebook / Gaming Notebook',
    description: 'ใช้เป็นทางเข้าหลักสำหรับโน๊ตบุ๊คทั่วไป โน๊ตบุ๊คเกมมิ่ง และหน้า hub แบรนด์เกมมิ่งที่เกี่ยวข้อง',
    links: [
      { label: 'รับซื้อโน๊ตบุ๊ค', href: '/บริการ/รับซื้อโน๊ตบุ๊ค' },
      { label: 'รับซื้อโน๊ตบุ๊คเกมมิ่ง', href: '/บริการ/รับซื้อโน๊ตบุ๊คเกมมิ่ง' },
      { label: 'รับซื้อ MSI Notebook', href: '/บริการ/รับซื้อ-msi-notebook' },
      { label: 'รับซื้อ ROG Gaming Notebook', href: '/บริการ/รับซื้อ-rog-gaming-notebook' },
    ],
  },
  {
    title: 'คอมพิวเตอร์ตั้งโต๊ะ / Desktop PC',
    description: 'เหมาะสำหรับคอมพิวเตอร์ตั้งโต๊ะทั่วไป Desktop PC มือสอง คอมประกอบ และคอมสเปกสูง',
    links: [
      { label: 'รับซื้อคอมพิวเตอร์ตั้งโต๊ะ', href: '/บริการ/รับซื้อคอมพิวเตอร์ตั้งโต๊ะ' },
      { label: 'รับซื้อ Desktop PC', href: '/บริการ/รับซื้อ-desktop-pc' },
      { label: 'รับซื้อ PC มือสอง', href: '/บริการ/รับซื้อ-pc-มือสอง' },
      { label: 'รับซื้อคอมประกอบ', href: '/บริการ/รับซื้อคอมประกอบ' },
      { label: 'รับซื้อคอมสเปกสูง', href: '/บริการ/รับซื้อคอมสเปกสูง' },
    ],
  },
  {
    title: 'Gaming PC / คอมเกมมิ่ง',
    description: 'ใช้เป็นทางเข้าหลักสำหรับ Gaming PC คอมเกมมิ่ง คอมร้านเกม และคอมสตรีมเกม',
    links: [
      { label: 'รับซื้อ Gaming PC', href: '/บริการ/รับซื้อ-gaming-pc' },
      { label: 'รับซื้อคอมเกมมิ่ง', href: '/บริการ/รับซื้อคอมเกมมิ่ง' },
      { label: 'รับซื้อคอมร้านเกม', href: '/บริการ/รับซื้อคอมร้านเกม' },
      { label: 'รับซื้อคอมสตรีมเกม', href: '/บริการ/รับซื้อคอมสตรีมเกม' },
    ],
  },
  {
    title: 'Workstation / Professional',
    description: 'สำหรับคอมทำงานกราฟิก ตัดต่อ งาน 3D งาน CAD และคอม AI / Deep Learning',
    links: [
      { label: 'รับซื้อ Workstation', href: '/บริการ/รับซื้อ-workstation' },
      { label: 'รับซื้อคอมทำงานกราฟิก', href: '/บริการ/รับซื้อคอมทำงานกราฟิก' },
      { label: 'รับซื้อคอมตัดต่อวิดีโอ', href: '/บริการ/รับซื้อคอมตัดต่อวิดีโอ' },
      { label: 'รับซื้อคอม AI / Deep Learning', href: '/บริการ/รับซื้อคอม-ai-deep-learning' },
    ],
  },
  {
    title: 'B2B / Company IT',
    description: 'เหมาะกับงานคอมบริษัท คอมสำนักงาน คอมยกล็อต และอุปกรณ์ไอทีขององค์กรที่ต้องการแยกบริบทจากงานผู้ใช้ทั่วไป',
    links: [
      { label: 'รับซื้อคอมบริษัท', href: '/บริการ/รับซื้อคอมบริษัท' },
      { label: 'รับซื้อคอมสำนักงาน', href: '/บริการ/รับซื้อคอมสำนักงาน' },
      { label: 'รับซื้อคอมยกล็อต', href: '/บริการ/รับซื้อคอมยกล็อต' },
      { label: 'รับซื้ออุปกรณ์ไอทีบริษัท', href: '/บริการ/รับซื้ออุปกรณ์ไอทีบริษัท' },
    ],
  },
];
---

<BaseLayout
  title="รับซื้อสินค้าไอทีมือสองทั่วประเทศ ส่งรูปประเมินฟรี"
  description="อำพล เทรดดิ้ง รับซื้อโน๊ตบุ๊ค คอม iPhone iPad MacBook กล้อง และอุปกรณ์ไอทีทั่วประเทศ ส่งรูปหรือรายการสินค้าเช็กราคาเบื้องต้นได้ มีหน้าร้านจริงที่อุบลราชธานี"
  canonical={pageUrl}
  breadcrumbs={breadcrumbs}
  pageType="CollectionPage"
  mainEntityId={schemaIds.itemList(pageUrl)}
  schemaExtras={schemaExtras}
>
  <header class="page-header">
    <div class="container">
      <span class="tag tag--orange" style="margin-bottom:.875rem;">รับซื้อทั่วประเทศ</span>
      <h1>รับซื้อสินค้าไอทีมือสองทั่วประเทศ</h1>
      <p class="page-header__desc">
        อำพล เทรดดิ้ง รับซื้อโน๊ตบุ๊ค คอมพิวเตอร์ iPhone iPad MacBook กล้อง และอุปกรณ์ไอทีจากลูกค้าทั่วประเทศ
        ส่งรูปหรือรายการสินค้าเพื่อประเมินราคาเบื้องต้นได้ · มีหน้าร้านจริงที่อุบลราชธานี ตรวจสอบได้
      </p>
      <div class="page-header__cta">
        <a href={site.line} class="btn btn--line" target="_blank" rel="noopener noreferrer">
          ส่งรูปประเมินทาง LINE @webuy
        </a>
        <a href={`tel:${site.phoneTel}`} class="btn btn--ghost">
          โทร {site.phone}
        </a>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="prose" style="max-width:800px; margin-bottom: 2.5rem; text-align: left;">
        <span class="eyebrow">หมวดหมู่สินค้า</span>
        <h2>สินค้าไอทีที่รับซื้อ</h2>
        <p>
          AMPHON TRADING รับซื้อสินค้าไอทีมือสองหลายประเภทจากลูกค้าทั่วประเทศ ครอบคลุมแบรนด์ชั้นนำอย่าง Apple, Samsung, ASUS, Acer, Dell และอื่นๆ
          ลูกค้าต่างจังหวัดส่งรูปหรือ Inventory List เพื่อประเมินราคาเบื้องต้นได้ก่อนตัดสินใจ
          ลูกค้าใกล้อุบลราชธานีสามารถนำสินค้ามาที่หน้าร้านได้ การนัดรับหรือจัดส่งขึ้นอยู่กับประเภทสินค้า จำนวน และพื้นที่
        </p>
        <ul>
          <li><strong>กลุ่ม Apple (iOS/macOS):</strong> รับพิจารณา iPhone หลายรุ่น (ตั้งแต่ iPhone 11 ขึ้นไป), iPad (Gen, Air, Pro), MacBook (Air/Pro ชิป M1, M2, M3), iMac และ Apple Watch</li>
          <li><strong>กลุ่มโน๊ตบุ๊คและคอมพิวเตอร์:</strong> รับซื้อ Notebook ทั้งสายทำงานและสายเกมมิ่ง คอมพิวเตอร์ตั้งโต๊ะ (PC) All-in-One PC จอมอนิเตอร์ และคอมพิวเตอร์สำนักงานแบบหลายเครื่อง</li>
          <li><strong>กลุ่มกล้องและสมาร์ทโฟนอื่นๆ:</strong> รับซื้อกล้อง DSLR Mirrorless เลนส์กล้อง จากค่าย Sony, Canon, Nikon และสมาร์ทโฟน Android รุ่นเรือธง (Samsung Galaxy S/Z Series)</li>
        </ul>
        <p>เลือกประเภทสินค้าด้านล่างเพื่อดูรายละเอียด หรือหากสินค้าไม่อยู่ในหมวดหมู่เหล่านี้ ส่งรูปมาสอบถามทาง LINE @webuy ได้ครับ ประเมินตามสภาพจริง เปรียบเทียบราคาก่อนได้</p>
      </div>
      <div class="grid grid--3" style="margin-bottom: 2.5rem;">
        {serviceHubGroups.map((group) => (
          <div class="card">
            <h3 style="margin-bottom:0.75rem;">{group.title}</h3>
            <p style="margin-bottom:1rem;">{group.description}</p>
            <ul style="margin:0; padding-left:1.1rem; display:grid; gap:0.5rem;">
              {group.links.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="grid grid--2">
        {services.map((service) => (
          <ServiceCard
            title={service.data.title}
            description={service.data.description}
            href={`/บริการ/${service.data.slug}`}
            keyword={service.data.mainKeyword}
            image={service.data.heroImage || serviceThumbnails[service.data.slug]}
          />
        ))}
      </div>
    </div>
  </section>

  <CTAContact />
</BaseLayout>
