---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAContact from '../components/CTAContact.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getCollection } from 'astro:content';
import { absoluteUrl, schemaIds, createItemListSchema } from '../lib/seo';
import { serviceThumbnails } from '../config/images';
import { site } from '../config/site';

const services = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const breadcrumbs = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'บริการรับซื้อสินค้าไอที' },
];
const pageUrl = absoluteUrl('/รับซื้อสินค้าไอที');

const schemaExtras = [
  createItemListSchema({
    pageUrl,
    name: 'บริการรับซื้อสินค้าไอทีทั้งหมด',
    items: services.map((s) => ({
      name: s.data.title,
      url: absoluteUrl(`/บริการ/${s.data.slug}`),
      description: s.data.description,
    })),
  }),
];
---

<BaseLayout
  title="รับซื้อสินค้าไอทีมือสองทั่วประเทศ ส่งรูปประเมินฟรี"
  description="อำพล เทรดดิ้ง รับซื้อโน๊ตบุ๊ค คอม iPhone iPad MacBook กล้อง และอุปกรณ์ไอทีทั่วประเทศ ส่งรูปหรือรายการสินค้าเช็กราคาเบื้องต้นได้ มีหน้าร้านจริงที่อุบลราชธานี"
  canonical={pageUrl}
  breadcrumbs={breadcrumbs}
  pageType="CollectionPage"
  mainEntityId={schemaIds.itemList(pageUrl)}
  schemaExtras={schemaExtras}
>
  <header class="page-header">
    <div class="container">
      <span class="tag tag--orange" style="margin-bottom:.875rem;">รับซื้อทั่วประเทศ</span>
      <h1>รับซื้อสินค้าไอทีมือสองทั่วประเทศ</h1>
      <p class="page-header__desc">
        อำพล เทรดดิ้ง รับซื้อโน๊ตบุ๊ค คอมพิวเตอร์ iPhone iPad MacBook กล้อง และอุปกรณ์ไอทีจากลูกค้าทั่วประเทศ
        ส่งรูปหรือรายการสินค้าเพื่อประเมินราคาเบื้องต้นได้ · มีหน้าร้านจริงที่อุบลราชธานี ตรวจสอบได้
      </p>
      <div class="page-header__cta">
        <a href={site.line} class="btn btn--line" target="_blank" rel="noopener noreferrer">
          ส่งรูปประเมินทาง LINE @webuy
        </a>
        <a href={`tel:${site.phoneTel}`} class="btn btn--ghost">
          โทร {site.phone}
        </a>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="prose" style="max-width:800px; margin-bottom: 2.5rem; text-align: left;">
        <span class="eyebrow">หมวดหมู่สินค้า</span>
        <h2>สินค้าไอทีที่รับซื้อ</h2>
        <p>
          AMPHON TRADING รับซื้อสินค้าไอทีมือสองหลายประเภทจากลูกค้าทั่วประเทศ ครอบคลุมแบรนด์ชั้นนำอย่าง Apple, Samsung, ASUS, Acer, Dell และอื่นๆ
          ลูกค้าต่างจังหวัดส่งรูปหรือ Inventory List เพื่อประเมินราคาเบื้องต้นได้ก่อนตัดสินใจ
          ลูกค้าใกล้อุบลราชธานีสามารถนำสินค้ามาที่หน้าร้านได้ การนัดรับหรือจัดส่งขึ้นอยู่กับประเภทสินค้า จำนวน และพื้นที่
        </p>
        <ul>
          <li><strong>กลุ่ม Apple (iOS/macOS):</strong> รับพิจารณา iPhone หลายรุ่น (ตั้งแต่ iPhone 11 ขึ้นไป), iPad (Gen, Air, Pro), MacBook (Air/Pro ชิป M1, M2, M3), iMac และ Apple Watch</li>
          <li><strong>กลุ่มโน๊ตบุ๊คและคอมพิวเตอร์:</strong> รับซื้อ Notebook ทั้งสายทำงานและสายเกมมิ่ง คอมพิวเตอร์ตั้งโต๊ะ (PC) All-in-One PC จอมอนิเตอร์ และคอมพิวเตอร์สำนักงานแบบหลายเครื่อง</li>
          <li><strong>กลุ่มกล้องและสมาร์ทโฟนอื่นๆ:</strong> รับซื้อกล้อง DSLR Mirrorless เลนส์กล้อง จากค่าย Sony, Canon, Nikon และสมาร์ทโฟน Android รุ่นเรือธง (Samsung Galaxy S/Z Series)</li>
        </ul>
        <p>เลือกประเภทสินค้าด้านล่างเพื่อดูรายละเอียด หรือหากสินค้าไม่อยู่ในหมวดหมู่เหล่านี้ ส่งรูปมาสอบถามทาง LINE @webuy ได้ครับ ประเมินตามสภาพจริง เปรียบเทียบราคาก่อนได้</p>
      </div>
      <div class="grid grid--2">
        {services.map((service) => (
          <ServiceCard
            title={service.data.title}
            description={service.data.description}
            href={`/บริการ/${service.data.slug}`}
            keyword={service.data.mainKeyword}
            image={service.data.heroImage || serviceThumbnails[service.data.slug]}
          />
        ))}
      </div>
    </div>
  </section>

  <CTAContact />
</BaseLayout>
