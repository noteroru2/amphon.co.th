---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAContact from '../components/CTAContact.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getCollection } from 'astro:content';
import { absoluteUrl, schemaIds, createItemListSchema } from '../lib/seo';
import { serviceThumbnails } from '../config/images';
import { site } from '../config/site';

const services = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const breadcrumbs = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'บริการรับซื้อสินค้าไอที' },
];
const pageUrl = absoluteUrl('/รับซื้อสินค้าไอที');

const schemaExtras = [
  createItemListSchema({
    pageUrl,
    name: 'บริการรับซื้อสินค้าไอทีทั้งหมด',
    items: services.map((s) => ({
      name: s.data.title,
      url: absoluteUrl(`/บริการ/${s.data.slug}`),
      description: s.data.description,
    })),
  }),
];
---

<BaseLayout
  title="รับซื้อสินค้าไอที ทุกประเภท — บริการรับซื้อครบทุกชนิด"
  description="รับซื้อสินค้าไอทีทุกชนิด โน๊ตบุ๊ค iPhone iPad MacBook คอมพิวเตอร์ กล้อง ราคาดี ประเมินฟรี นัดรับถึงที่"
  canonical={pageUrl}
  breadcrumbs={breadcrumbs}
  pageType="CollectionPage"
  mainEntityId={schemaIds.itemList(pageUrl)}
  schemaExtras={schemaExtras}
>
  <header class="page-header">
    <div class="container">
      <span class="tag tag--orange" style="margin-bottom:.875rem;">บริการรับซื้อ</span>
      <h1>รับซื้อสินค้าไอที ทุกชนิด ภาคอีสาน</h1>
      <p class="page-header__desc">
        รับซื้อสินค้าไอทีมือสองหลายประเภท ประเมินราคาฟรีผ่าน Line ไม่ต้องเดินทาง
      </p>
      <div class="page-header__cta">
        <a href={site.line} class="btn btn--line" target="_blank" rel="noopener noreferrer">
          แชท Line ประเมินราคา
        </a>
        <a href={`tel:${site.phoneTel}`} class="btn btn--ghost">
          โทร {site.phone}
        </a>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="prose" style="max-width:800px; margin-bottom: 2.5rem; text-align: left;">
        <span class="eyebrow">หมวดหมู่สินค้า</span>
        <h2>สินค้าไอทีที่เราให้ราคาสูงเป็นพิเศษ</h2>
        <p>
          AMPHON TRADING รับซื้อสินค้าไอทีทุกประเภท ครอบคลุมทั้งแบรนด์ชั้นนำอย่าง Apple, Samsung, ASUS, Acer, Dell และอื่นๆ โดยเราแบ่งหมวดหมู่หลักๆ ดังนี้:
        </p>
        <ul>
          <li><strong>กลุ่ม Apple (iOS/macOS):</strong> รับซื้อ iPhone ทุกรุ่น (เน้นตั้งแต่ iPhone 11 ขึ้นไป), iPad (Gen, Air, Pro), MacBook (Air/Pro ชิป M1, M2, M3), iMac, และ Apple Watch</li>
          <li><strong>กลุ่มโน๊ตบุ๊คและคอมพิวเตอร์:</strong> รับซื้อ Notebook ทั้งสายทำงานและสายเกมมิ่ง, คอมพิวเตอร์ตั้งโต๊ะ (PC), All-in-One PC, จอมอนิเตอร์ และเรารับซื้อคอมพิวเตอร์สำนักงานแบบเหมาจำนวนมาก</li>
          <li><strong>กลุ่มกล้องและสมาร์ทโฟนอื่นๆ:</strong> รับซื้อกล้อง DSLR, Mirrorless, เลนส์กล้อง จากค่าย Sony, Canon, Nikon และสมาร์ทโฟน Android รุ่นเรือธง (Samsung Galaxy S/Z Series)</li>
        </ul>
        <p>คุณสามารถคลิกเลือกประเภทสินค้าด้านล่างเพื่อดูรายละเอียดเพิ่มเติม หรือหากสินค้าของคุณไม่อยู่ในหมวดหมู่เหล่านี้ สามารถทัก Line มาสอบถามได้ทันทีครับ</p>
      </div>
      <div class="grid grid--2">
        {services.map((service) => (
          <ServiceCard
            title={service.data.title}
            description={service.data.description}
            href={`/บริการ/${service.data.slug}`}
            keyword={service.data.mainKeyword}
            image={serviceThumbnails[service.data.slug]}
          />
        ))}
      </div>
    </div>
  </section>

  <CTAContact />
</BaseLayout>
