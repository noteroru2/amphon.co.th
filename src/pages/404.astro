---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
import { absoluteUrl } from '../lib/seo';

const pageUrl = absoluteUrl('/404');

const quickLinks = [
  { label: 'รับซื้อ iPhone', href: '/บริการ/รับซื้อ-iphone' },
  { label: 'รับซื้อ MacBook', href: '/บริการ/รับซื้อ-macbook' },
  { label: 'รับซื้อโน๊ตบุ๊ค', href: '/บริการ/รับซื้อโน๊ตบุ๊ค' },
  { label: 'พื้นที่ให้บริการ', href: '/พื้นที่ให้บริการ' },
  { label: 'ติดต่อเรา', href: '/contact' },
  { label: 'เกี่ยวกับเรา', href: '/about' },
];
---

<BaseLayout
  title="ไม่พบหน้านี้ — 404"
  description="ไม่พบหน้าที่คุณกำลังมองหา กลับสู่หน้าแรก หรือติดต่อเราได้เลย"
  canonical={pageUrl}
  noindex={true}
  pageType="WebPage"
>
  <section class="not-found">
    <div class="container not-found__inner">

      <!-- Error message -->
      <div class="not-found__hero">
        <span class="not-found__code" aria-hidden="true">404</span>
        <h1>ไม่พบหน้านี้</h1>
        <p class="not-found__desc">
          หน้าที่คุณมองหาอาจถูกย้าย ลบ หรือ URL พิมพ์ผิด<br />
          กลับหน้าแรก หรือติดต่อเราเพื่อประเมินราคาสินค้าได้เลย
        </p>
        <a href="/" class="btn btn--outline not-found__home">← กลับหน้าแรก</a>
      </div>

      <!-- Contact CTAs -->
      <div class="not-found__contact">
        <p class="not-found__contact-label">ติดต่อเราได้ทันที</p>
        <div class="not-found__contact-grid">
          <a href={site.line} class="not-found__contact-card not-found__contact-card--line" target="_blank" rel="noopener noreferrer">
            <span class="not-found__contact-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 5.92 2 10.72c0 3.46 2.19 6.49 5.49 8.14-.19.68-.72 2.47-.83 2.86-.12.44.16.43.34.31.14-.09 2.26-1.52 3.17-2.14.59.09 1.2.13 1.83.13 5.52 0 10-3.92 10-8.72S17.52 2 12 2z"/></svg>
            </span>
            <span class="not-found__contact-title">แชท Line</span>
            <span class="not-found__contact-value">{site.lineId}</span>
            <span class="not-found__contact-hint">ส่งรูปประเมินราคาฟรี</span>
          </a>
          <a href={`tel:${site.phoneTel}`} class="not-found__contact-card not-found__contact-card--phone">
            <span class="not-found__contact-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013 5.18 2 2 0 015 3h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L9.09 10.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 17z"/></svg>
            </span>
            <span class="not-found__contact-title">โทรศัพท์</span>
            <span class="not-found__contact-value">{site.phone}</span>
            <span class="not-found__contact-hint">ทุกวัน 09:00–21:00 น.</span>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div class="not-found__links">
        <p class="not-found__links-label">หน้าที่อาจเป็นประโยชน์</p>
        <ul class="not-found__links-grid">
          {quickLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    padding-block: 3rem 5rem;
    background: var(--color-bg);
  }

  .not-found__inner {
    max-width: 36rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* ---- Hero ---- */
  .not-found__hero {
    text-align: center;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 2.5rem 2rem 2rem;
    box-shadow: var(--shadow-sm);
  }

  .not-found__code {
    display: block;
    font-size: clamp(4rem, 18vw, 6rem);
    font-weight: 800;
    line-height: 1;
    color: var(--color-primary);
    opacity: 0.18;
    margin-bottom: 0.25rem;
    letter-spacing: -0.04em;
    user-select: none;
  }

  .not-found__hero h1 {
    font-size: clamp(1.375rem, 4vw, 1.875rem);
    font-weight: 800;
    color: var(--color-dark);
    margin-bottom: 0.75rem;
  }

  .not-found__desc {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .not-found__home {
    display: inline-flex;
  }

  /* ---- Contact cards ---- */
  .not-found__contact-label,
  .not-found__links-label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
    text-align: center;
  }

  .not-found__contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.875rem;
  }

  @media (max-width: 480px) {
    .not-found__contact-grid {
      grid-template-columns: 1fr;
    }
  }

  .not-found__contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.25rem;
    padding: 1.25rem 1rem;
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    border: 2px solid transparent;
  }

  .not-found__contact-card:hover {
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .not-found__contact-card--line {
    background: #06c755;
    color: #fff;
    border-color: #06c755;
  }

  .not-found__contact-card--line:hover {
    background: #05b04c;
    border-color: #05b04c;
    color: #fff;
  }

  .not-found__contact-card--phone {
    background: var(--color-dark);
    color: #fff;
    border-color: var(--color-dark);
  }

  .not-found__contact-card--phone:hover {
    background: var(--color-navy);
    border-color: var(--color-navy);
    color: #fff;
  }

  .not-found__contact-icon {
    display: flex;
    margin-bottom: 0.375rem;
    opacity: 0.9;
  }

  .not-found__contact-title {
    font-size: 0.8125rem;
    font-weight: 600;
    opacity: 0.85;
    letter-spacing: 0.02em;
  }

  .not-found__contact-value {
    font-size: 1.125rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    line-height: 1.3;
  }

  .not-found__contact-hint {
    font-size: 0.75rem;
    opacity: 0.75;
    margin-top: 0.125rem;
  }

  /* ---- Quick links ---- */
  .not-found__links {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
  }

  .not-found__links-label {
    text-align: left;
    margin-bottom: 0.875rem;
  }

  .not-found__links-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem 1rem;
  }

  @media (max-width: 380px) {
    .not-found__links-grid {
      grid-template-columns: 1fr;
    }
  }

  .not-found__links-grid a {
    display: block;
    color: var(--color-primary-dark);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    padding: 0.25rem 0;
  }

  .not-found__links-grid a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }
</style>
