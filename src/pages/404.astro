---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
import { absoluteUrl } from '../lib/seo';

const pageUrl = absoluteUrl('/404');
---

<BaseLayout
  title="ไม่พบหน้านี้ — 404"
  description="ไม่พบหน้าที่คุณกำลังมองหา กลับสู่หน้าแรก หรือติดต่อเราได้เลย"
  canonical={pageUrl}
  noindex={true}
  pageType="WebPage"
>
  <section class="not-found">
    <div class="container not-found__inner">
      <div class="not-found__code">404</div>
      <h1 class="not-found__title">ไม่พบหน้านี้</h1>
      <p class="not-found__desc">
        หน้าที่คุณมองหาอาจถูกย้าย, ลบ, หรือ URL อาจพิมพ์ผิด<br />
        ลองกลับสู่หน้าแรก หรือติดต่อเราได้เลยครับ
      </p>

      <div class="not-found__actions">
        <a href="/" class="btn btn--primary">← กลับหน้าแรก</a>
        <a href={site.line} class="btn btn--line" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.48 2 2 5.92 2 10.72c0 3.46 2.19 6.49 5.49 8.14-.19.68-.72 2.47-.83 2.86-.12.44.16.43.34.31.14-.09 2.26-1.52 3.17-2.14.59.09 1.2.13 1.83.13 5.52 0 10-3.92 10-8.72S17.52 2 12 2z"/>
          </svg>
          แชท Line {site.lineId}
        </a>
        <a href={`tel:${site.phoneTel}`} class="btn btn--ghost">
          📞 โทร {site.phone}
        </a>
      </div>

      <div class="not-found__links">
        <p class="not-found__links-label">หน้าที่อาจเป็นประโยชน์</p>
        <ul>
          <li><a href="/บริการ/รับซื้อ-iphone">รับซื้อ iPhone</a></li>
          <li><a href="/บริการ/รับซื้อ-macbook">รับซื้อ MacBook</a></li>
          <li><a href="/บริการ/รับซื้อโน๊ตบุ๊ค">รับซื้อโน๊ตบุ๊ค</a></li>
          <li><a href="/พื้นที่ให้บริการ">พื้นที่ให้บริการ</a></li>
          <li><a href="/contact">ติดต่อเรา</a></li>
          <li><a href="/about">เกี่ยวกับเรา</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
    padding-block: 5rem;
    text-align: center;
  }

  .not-found__inner {
    max-width: 40rem;
    margin-inline: auto;
  }

  .not-found__code {
    font-size: clamp(5rem, 20vw, 8rem);
    font-weight: 800;
    line-height: 1;
    color: var(--color-primary);
    opacity: 0.15;
    margin-bottom: -1rem;
    letter-spacing: -0.04em;
  }

  .not-found__title {
    font-size: clamp(1.5rem, 5vw, 2.25rem);
    font-weight: 800;
    color: var(--color-dark);
    margin-bottom: 1rem;
  }

  .not-found__desc {
    color: var(--color-muted);
    font-size: 1.0625rem;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .not-found__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 2.5rem;
  }

  .not-found__links {
    text-align: left;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
  }

  .not-found__links-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .not-found__links ul {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .not-found__links a {
    color: var(--color-primary-dark);
    font-size: 0.9375rem;
    text-decoration: none;
    font-weight: 500;
  }

  .not-found__links a:hover {
    text-decoration: underline;
    color: var(--color-primary);
  }
</style>
