---
import { getCollection } from 'astro:content';
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import { getRelatedServicesForEntry } from '../../config/service-clusters';

export async function getStaticPaths() {
  const services = await getCollection('services', ({ data }) => !data.draft);
  const serviceAreas = await getCollection('serviceAreas', ({ data }) => !data.draft);

  return services.map((entry) => ({
    params: { slug: entry.data.slug },
    props: {
      entry,
      relatedAreas: serviceAreas.filter((sa) => sa.data.serviceSlug === entry.data.slug),
      otherServices: getRelatedServicesForEntry(entry, services, 12),
    },
  }));
}

const { entry, relatedAreas, otherServices } = Astro.props;
---

<ServiceLayout entry={entry} relatedAreas={relatedAreas} otherServices={otherServices} />
