---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import CTAContact from '../../components/CTAContact.astro';
import RescueLinkGroups from '../../components/RescueLinkGroups.astro';
import { getCollection } from 'astro:content';
import { absoluteUrl, schemaIds, createItemListSchema } from '../../lib/seo';
import { buildSeoRescueGroups } from '../../config/seo-rescue';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const services = (await getCollection('services', ({ data }) => !data.draft)).sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
);
const rescueGroups = buildSeoRescueGroups(services);

const breadcrumbs = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'บทความ' },
];

const pageUrl = absoluteUrl('/blog');
const schemaExtras = [
  createItemListSchema({
    pageUrl,
    name: 'บทความและคำแนะนำ',
    items: posts.map((post) => ({
      name: post.data.title,
      url: absoluteUrl(`/blog/${post.data.slug}`),
      description: post.data.description,
    })),
  }),
];
---

<BaseLayout
  title="บทความและคำแนะนำ"
  description="บทความคำแนะนำการขายสินค้าไอที เช็กราคา เตรียมเครื่อง และวางแผนก่อนส่งขาย"
  canonical={pageUrl}
  breadcrumbs={breadcrumbs}
  pageType="CollectionPage"
  mainEntityId={schemaIds.itemList(pageUrl)}
  schemaExtras={schemaExtras}
>
  <header class="page-header">
    <div class="container">
      <span class="tag tag--orange" style="margin-bottom:.875rem;">สาระความรู้</span>
      <h1>บทความและคำแนะนำ</h1>
      <p class="page-header__desc">
        แหล่งรวมคำแนะนำ วิธีเช็กสภาพเครื่อง และข้อมูลที่ควรรู้ก่อนขายสินค้าไอที
      </p>
      <div class="prose" style="max-width:800px; margin: 2rem auto 0; text-align: left;">
        <p style="font-size: 1.1rem; color: var(--color-gray-600);">
          บทความชุดนี้รวบคำแนะนำก่อนขาย <strong>โน๊ตบุ๊ค, iPhone, iPad, MacBook, คอมพิวเตอร์ และอุปกรณ์ไอทีมือสอง</strong>
          เพื่อช่วยเตรียมข้อมูลให้ครบ เช็กสภาพเครื่องอย่างเป็นระบบ และตัดสินใจขายได้ง่ายขึ้น
          เรารวมทั้งวิธีล้างข้อมูล วิธีเช็กแบตเตอรี่ วิธีประเมินสภาพเครื่อง และข้อควรระวังก่อนส่งมอบสินค้า
          เพื่อให้คุณคุยรายละเอียดกับร้านรับซื้อได้ตรงขึ้นและวางแผนก่อนขายได้สะดวกกว่าเดิม
        </p>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="grid grid--3">
        {posts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.data.slug}`}
            date={post.data.date}
            tags={post.data.tags}
          />
        ))}
      </div>
    </div>
  </section>

  <RescueLinkGroups
    eyebrow="บทความเชื่อมหน้าบริการ"
    title="ทางลัดไปหน้าบริการหลักและหน้ารุ่นย่อย"
    description="ใช้หน้าบทความเป็นอีกหนึ่ง hub สำหรับเชื่อมไปยังบริการที่มี intent ชัดเจน ช่วยเพิ่มเส้นทาง crawl จากบทความเข้าสู่หน้ารับซื้อโดยตรง."
    groups={rescueGroups}
  />

  <CTAContact compact title="มีสินค้าอยากขาย? ปรึกษาทีมงาน Amphon ฟรี" />
</BaseLayout>
