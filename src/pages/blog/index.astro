---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import CTAContact from '../../components/CTAContact.astro';
import { getCollection } from 'astro:content';
import { absoluteUrl, schemaIds, createItemListSchema } from '../../lib/seo';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const breadcrumbs = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'บทความ' },
];

const pageUrl = absoluteUrl('/blog');
const schemaExtras = [
  createItemListSchema({
    pageUrl,
    name: 'บทความและคำแนะนำ',
    items: posts.map((post) => ({
      name: post.data.title,
      url: absoluteUrl(`/blog/${post.data.slug}`),
      description: post.data.description,
    })),
  }),
];
---

<BaseLayout
  title="บทความและคำแนะนำ"
  description="บทความคำแนะนำการขายสินค้าไอที เช็กราคา เตรียมเครื่อง และเทคนิคให้ได้ราคาดี"
  canonical={pageUrl}
  breadcrumbs={breadcrumbs}
  pageType="CollectionPage"
  mainEntityId={schemaIds.itemList(pageUrl)}
  schemaExtras={schemaExtras}
>
  <header class="page-header">
    <div class="container">
      <span class="tag tag--orange" style="margin-bottom:.875rem;">สาระความรู้</span>
      <h1>บทความและคำแนะนำ</h1>
      <p class="page-header__desc">
        แหล่งรวมความรู้ เคล็ดลับ และวิธีเช็คราคาก่อนตัดสินใจขายสินค้าไอที
      </p>
      <div class="prose" style="max-width:800px; margin: 2rem auto 0; text-align: left;">
        <p style="font-size: 1.1rem; color: var(--color-gray-600);">
          การนำอุปกรณ์ไอทีมือสอง ไม่ว่าจะเป็น <strong>โน๊ตบุ๊ค, สมาร์ทโฟน (iPhone, Samsung), แท็บเล็ต (iPad), หรือคอมพิวเตอร์</strong> มาขายต่อ จำเป็นต้องมีการเตรียมตัวที่ดีเพื่อให้ได้ <strong>"ราคาที่สูงที่สุด"</strong> 
          และปกป้องข้อมูลส่วนตัวของคุณ ที่ AMPHON TRADING เราได้รวบรวมบทความน่ารู้ ไม่ว่าจะเป็นวิธีล้างข้อมูล (Format/Factory Reset), การเช็คสภาพแบตเตอรี่, การประเมินราคาตลาด, 
          รวมถึงข้อควรระวังก่อนส่งมอบเครื่องให้ร้านรับซื้อ เพื่อให้คุณขายได้อย่างมั่นใจและปลอดภัยที่สุด
        </p>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="grid grid--3">
        {posts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.data.slug}`}
            date={post.data.date}
            tags={post.data.tags}
          />
        ))}
      </div>
    </div>
  </section>

  <CTAContact compact title="มีสินค้าอยากขาย? ปรึกษาทีมงาน Amphon ฟรี" />
</BaseLayout>
