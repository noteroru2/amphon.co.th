---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAContact from '../components/CTAContact.astro';
import ProvinceGrid from '../components/ProvinceGrid.astro';
import { getCollection } from 'astro:content';
import { absoluteUrl, schemaIds, createItemListSchema } from '../lib/seo';

const areas = await getCollection('areas', ({ data }) => !data.draft);

const breadcrumbs = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'พื้นที่ให้บริการ' },
];

const pageUrl = absoluteUrl('/พื้นที่ให้บริการ');
const areaItems = areas.map((a) => ({
  name: a.data.title,
  url: absoluteUrl(`/พื้นที่ให้บริการ/${a.data.slug}`),
  description: a.data.description,
}));

const schemaExtras = [
  createItemListSchema({
    pageUrl,
    name: 'พื้นที่ให้บริการภาคอีสาน',
    items: areaItems,
  }),
];
---

<BaseLayout
  title="พื้นที่ให้บริการ ภาคอีสาน"
  description="Amphon ให้บริการรับซื้อสินค้าไอทีหลายประเภททั่วภาคอีสาน 20 จังหวัด นัดรับหรือประสานขนส่งตามข้อตกลง ประเมินราคาฟรี"
  canonical={pageUrl}
  breadcrumbs={breadcrumbs}
  pageType="CollectionPage"
  mainEntityId={schemaIds.itemList(pageUrl)}
  schemaExtras={schemaExtras}
>
  <header class="page-header">
    <div class="container">
      <span class="tag tag--orange" style="margin-bottom:.875rem;">พื้นที่ให้บริการ</span>
      <h1>พื้นที่ให้บริการรับซื้อสินค้าไอที</h1>
      <p class="page-header__desc">
        ให้บริการรับซื้อสินค้าไอทีครอบคลุม 20 จังหวัดภาคอีสาน นัดรับหรือประสานขนส่งตามพื้นที่ ประเภทสินค้า และจำนวน
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="section-header section-header--left">
        <span class="eyebrow">20 จังหวัด ภาคอีสาน</span>
        <h2>เลือกจังหวัดของคุณ</h2>
        <p>รับซื้อสินค้าไอทีทั่วภาคอีสาน ส่งรูปประเมินราคาฟรีได้ทุกจังหวัด</p>
      </div>
      <ProvinceGrid
        provinces={areas.map((area) => ({
          title: area.data.title,
          slug: area.data.slug,
          description: area.data.description,
        }))}
      />

      <div class="prose" style="max-width:800px; margin: 3rem auto 0; text-align: left;">
        <h3 style="font-size: 1.25rem;">การรับซื้อสินค้าไอทีครอบคลุมทั้ง 20 จังหวัดในภาคอีสาน</h3>
        <p>
          AMPHON TRADING เป็นศูนย์กลางการ<strong>รับซื้ออุปกรณ์ไอทีมือสอง</strong>ที่ใหญ่ที่สุดในระดับภูมิภาคอีสาน (ตะวันออกเฉียงเหนือ) 
          เรารองรับการประเมินราคาผ่านระบบออนไลน์ (Line) ที่สะดวก รวดเร็ว และแม่นยำที่สุด โดยลูกค้าจากทั้ง 20 จังหวัด ได้แก่ 
          <strong>อุบลราชธานี, ขอนแก่น, นครราชสีมา (โคราช), อุดรธานี, บุรีรัมย์, สุรินทร์, ศรีสะเกษ, ร้อยเอ็ด, มหาสารคาม, ชัยภูมิ, กาฬสินธุ์, สกลนคร, นครพนม, มุกดาหาร, เลย, หนองคาย, หนองบัวลำภู, อำนาจเจริญ, ยโสธร และบึงกาฬ</strong>
          สามารถส่งสเปกและรูปถ่ายเครื่องมาให้เราตีราคาได้ฟรี 100%
        </p>
        <p>
          <strong>นัดรับตามพื้นที่และเงื่อนไขที่ตกลง (On-site Pickup):</strong> สำหรับลูกค้าในจังหวัดที่มีระยะทางไม่ไกล หรือมีสินค้ามูลค่าสูง / จำนวนหลายเครื่อง (เช่น โละคอมพิวเตอร์สำนักงาน) ทางเรามีทีมงานขับรถไปนัดรับตามพื้นที่และเงื่อนไขที่ตกลง พร้อมตรวจเช็คสภาพและชำระเงินหลังตรวจสอบสินค้าและตกลงราคา ส่วนลูกค้าจังหวัดอื่นๆ สามารถจัดส่งพัสดุมาที่เรา เมื่อของถึงและตรวจสอบผ่าน เราโอนชำระเงินเข้าบัญชีให้คุณตามตกลง
        </p>
      </div>
    </div>
  </section>

  <CTAContact title="อยู่ในภาคอีสาน? นัดรับหรือประสานขนส่งตามข้อตกลง" />
</BaseLayout>
