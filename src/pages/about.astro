---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAContact from '../components/CTAContact.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { imageAlt } from '../config/images';
import { site } from '../config/site';
import { absoluteUrl } from '../lib/seo';

const breadcrumbs = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'เกี่ยวกับเรา' },
];

const pageUrl = absoluteUrl('/about');

const gallery = [
  {
    src: '/images/about/amphon-trading-storefront-ubon.webp',
    caption: 'หน้าร้านอำพล เทรดดิ้ง 740/8 ถนนชยางกูร อุบลราชธานี',
  },
  {
    src: '/images/about/amphon-trading-shop-showroom.webp',
    caption: 'บรรยากาศหน้าร้าน รับซื้อขายไอที มือถือ คอมพิวเตอร์ ทีวี',
  },
  {
    src: '/images/about/amphon-trading-shop-interior-evaluation.webp',
    caption: 'ทีมงานตรวจสอบและประเมินราคาสินค้าไอทีมือสอง',
  },
  {
    src: '/images/about/amphon-trading-shop-transaction.webp',
    caption: 'บริการรับซื้อสินค้าไอที ตรวจสอบและชำระเงินหลังตรวจสอบสินค้า',
  },
];
---

<BaseLayout
  title="เกี่ยวกับเรา"
  description="อำพล เทรดดิ้ง รับซื้อสินค้าไอทีมือสองทั่วภาคอีสาน มีหน้าร้านจริง อุบลราชธานี ทีมงานมืออาชีพ ประเมินราคาโปร่งใส ชำระเงินหลังตกลงราคา"
  canonical={pageUrl}
  ogImage="/images/about/amphon-trading-storefront-ubon.webp"
  breadcrumbs={breadcrumbs}
  pageType="AboutPage"
>
  <header class="page-header">
    <div class="container page-header__grid">
      <div>
        <span class="tag tag--orange" style="margin-bottom:.875rem;">AMPHON TRADING</span>
        <h1>เกี่ยวกับ อำพล เทรดดิ้ง</h1>
        <p class="page-header__desc">
          ผู้เชี่ยวชาญด้านการรับซื้อสินค้าไอทีและอิเล็กทรอนิกส์ในภาคอีสาน มีหน้าร้านจริง อุบลราชธานี
        </p>
      </div>
      <figure class="page-header__figure">
        <OptimizedImage
          src="/images/hero/hero-amphon-storefront-ubon-banner.webp"
          alt={imageAlt['/images/hero/hero-amphon-storefront-ubon-banner.webp']}
          loading="eager"
          width={600}
          height={338}
        />
      </figure>
    </div>
  </header>

  <div class="container">
    <article class="prose" style="padding-block: 2rem 1rem;">
      <h2>เกี่ยวกับเรา: AMPHON TRADING คือใคร?</h2>
      <p>
        <strong>อำพล เทรดดิ้ง (AMPHON TRADING)</strong> คือศูนย์กลางการรับซื้อสินค้าไอทีและอิเล็กทรอนิกส์มือสองที่ใหญ่และน่าเชื่อถือที่สุดแห่งหนึ่งในภาคอีสาน
        ตั้งอยู่ที่ 740/8 ถนนชยางกูร อุบลราชธานี เราเริ่มต้นธุรกิจจากความหลงใหลในเทคโนโลยีคอมพิวเตอร์และสมาร์ทโฟน 
        บวกกับความตั้งใจที่จะสร้างมาตรฐานใหม่ให้กับวงการ "รับซื้อของมือสอง" ให้มีความโปร่งใส ไม่กดราคา และเป็นธรรมกับผู้ขายมากที่สุด
      </p>

      <h2>วิสัยทัศน์และพันธกิจของเรา</h2>
      <p>
        <strong>วิสัยทัศน์ (Vision):</strong> มุ่งมั่นเป็นผู้นำชั้นนำด้านการรับซื้ออุปกรณ์ไอทีมือสองในภาคอีสาน ที่ลูกค้าไว้วางใจและนึกถึงเป็นชื่อแรก
        <br/><br/>
        <strong>พันธกิจ (Mission):</strong>
      </p>
      <ul>
        <li>ให้บริการประเมินราคาที่แม่นยำ อิงตามราคาตลาดโลกและสภาพเครื่องจริง</li>
        <li>ปกป้องข้อมูลส่วนบุคคลของลูกค้าด้วยขั้นตอนการล้างข้อมูล (Data Wiping) เพื่อความปลอดภัยก่อนส่งมอบ</li>
        <li>อำนวยความสะดวกด้วยบริการนัดรับหรือประสานขนส่งตามพื้นที่ ประเภทสินค้า และจำนวน ครอบคลุมหลายพื้นที่ในภาคอีสาน</li>
      </ul>

      <h2>สิ่งที่เราเชี่ยวชาญและรับซื้อ</h2>
      <p>เรามีทีมช่างผู้เชี่ยวชาญที่สามารถประเมินฮาร์ดแวร์ได้หลากหลายประเภท ไม่ว่าจะเป็น:</p>
      <ul>
        <li><strong>คอมพิวเตอร์และโน๊ตบุ๊ค:</strong> โน๊ตบุ๊คทุกยี่ห้อ (ASUS, Acer, Lenovo, Dell, HP), คอมพิวเตอร์ประกอบ, คอมพิวเตอร์บริษัทที่ปลดระวาง</li>
        <li><strong>Apple Products:</strong> iPhone, iPad, MacBook Air/Pro, iMac และ Apple Watch หลายรุ่น</li>
        <li><strong>กล้องถ่ายรูป:</strong> กล้อง DSLR, Mirrorless, เลนส์กล้อง จากแบรนด์ชั้นนำ (Sony, Canon, Nikon, Fujifilm)</li>
        <li><strong>อุปกรณ์อื่นๆ:</strong> จอมอนิเตอร์สเปกสูง, อุปกรณ์เกมมิ่ง ฯลฯ</li>
      </ul>

      <h2>ทำไมลูกค้ากว่าร้อยรายจึงไว้วางใจ AMPHON TRADING?</h2>
      <p>เพราะเราเข้าใจว่าการขายของชิ้นโปรด คุณย่อมคาดหวังราคาที่เป็นธรรมและเปรียบเทียบได้ก่อนตัดสินใจ รวมถึงความปลอดภัย นี่คือสิ่งที่เรายึดมั่น:</p>
      <ul>
        <li><strong>ประเมินราคาฟรี ไม่มีข้อผูกมัด:</strong> แค่ส่งรูปมาทาง Line เราตีราคาให้ฟรี ไม่พอใจราคายังไม่ต้องขาย</li>
        <li><strong>ราคายุติธรรม:</strong> เราไม่ใช้วิธีหลอกให้ราคาป้ายสูงๆ แล้วไปหักจุกจิกหน้างาน หากเครื่องสภาพตรงตามรูป เราจ่ายเต็มจำนวน</li>
        <li><strong>ปลอดภัยเรื่องข้อมูล:</strong> ก่อนจะนำเครื่องไปขายต่อ เรา Format และ Factory Reset ลบข้อมูลเครื่องอย่างปลอดภัย</li>
        <li><strong>การชำระเงิน:</strong> ตรวจเครื่องเสร็จ ชำระเงินเข้าบัญชีหรือเงินสดตามข้อตกลงหลังตรวจสอบสินค้าเรียบร้อย</li>
        <li><strong>มีหน้าร้านจริง ตรวจสอบได้:</strong> เราจดทะเบียนถูกต้อง มีหน้าร้านชัดเจนที่จังหวัดอุบลราชธานี ลูกค้าจึงมั่นใจได้ว่าไม่ถูกโกง</li>
      </ul>
    </article>

    <div class="about-gallery">
      {gallery.map((item) => (
        <figure class="about-gallery__item">
          <OptimizedImage src={item.src} alt={imageAlt[item.src] ?? item.caption} loading="lazy" width={600} height={375} />
          <figcaption>{item.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>

  <CTAContact />
</BaseLayout>
