---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAContact from '../components/CTAContact.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProvinceGrid from '../components/ProvinceGrid.astro';
import ArticleCard from '../components/ArticleCard.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import RescueLinkGroups from '../components/RescueLinkGroups.astro';
import { categoryImages, serviceThumbnails, imageAlt } from '../config/images';
import { getCollection } from 'astro:content';
import { site } from '../config/site';
import { absoluteUrl, schemaIds, createItemListSchema, createOfferCatalogSchema } from '../lib/seo';
import { buildSeoRescueGroups } from '../config/seo-rescue';

const allServices = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
const services = allServices.slice(0, 8);
const rescueGroups = buildSeoRescueGroups(allServices);

const homepageServiceCardCopy: Record<string, { title: string; description: string; imageAlt?: string }> = {
  'รับซื้อ-ipad-pro': {
    title: 'รับซื้อ iPad Pro มือสอง หลายรุ่น M1 M2 M4',
    description:
      'รับซื้อ iPad Pro มือสอง หลายขนาด ชิป M1 M2 M4 รุ่น Wi-Fi และ Cellular ส่งรูปเช็กราคาได้ ประเมินตามรุ่น สภาพ และอุปกรณ์',
  },
  'รับซื้อคอมสำนักงาน': {
    title: 'รับซื้อคอมสำนักงาน คอมพิวเตอร์ออฟฟิศหลายเครื่อง',
    description:
      'รับซื้อคอมสำนักงาน PC ออฟฟิศแบรนด์เนม Dell, HP, Lenovo รวมจอคอม Printer และ UPS ส่งรูปหรือ Inventory List ประเมินเบื้องต้นได้',
  },
  'รับซื้อโน๊ตบุ๊ค': {
    title: 'รับซื้อโน๊ตบุ๊คมือสอง ประเมินตามสภาพจริง',
    description:
      'รับซื้อโน๊ตบุ๊คมือสองหลายแบรนด์ ทั้งเครื่องใช้งานได้ เครื่องมีตำหนิ เกมมิ่ง และโน๊ตบุ๊คบริษัท ส่งรูปเช็กราคาได้',
    imageAlt: 'รับซื้อโน๊ตบุ๊คมือสอง ประเมินตามสเปกและสภาพจริง อำพล เทรดดิ้ง',
  },
  'รับซื้อ-ipad-air': {
    title: 'รับซื้อ iPad Air มือสอง M1 M2 M3 หลายความจุ',
    description:
      'รับซื้อ iPad Air 4, Air 5 (M1), Air M2 และ Air M3 ส่งรูปและสภาพเครื่อง ประเมินราคาเบื้องต้นจากรูปได้',
    imageAlt: 'รับซื้อ iPad Air มือสอง ประเมินตามรุ่น สภาพ และอุปกรณ์ อำพล เทรดดิ้ง',
  },
};
const areas    = (await getCollection('areas',    ({ data }) => !data.draft)).slice(0, 8);
const posts    = (await getCollection('blog',     ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const breadcrumbs = [{ label: 'หน้าแรก' }];
const pageUrl = absoluteUrl('/');

const serviceItems = services.map((s) => ({
  name: s.data.title,
  url: absoluteUrl(`/บริการ/${s.data.slug}`),
  description: s.data.description,
}));

const schemaExtras = [
  createOfferCatalogSchema({ pageUrl, name: 'บริการรับซื้อสินค้าไอที', items: serviceItems }),
  createItemListSchema({
    pageUrl,
    name: 'พื้นที่ที่สะดวกสำหรับนัดรับและเข้าร้าน',
    items: areas.map((a) => ({
      name: a.data.title,
      url: absoluteUrl(`/พื้นที่ให้บริการ/${a.data.slug}`),
      description: a.data.description,
    })),
  }),
];

const categories = [
  { label: 'คอม / โน๊ตบุ๊ค', href: '/บริการ/รับซื้อโน๊ตบุ๊ค' },
  { label: 'iPhone / iPad / MacBook', href: '/บริการ/รับซื้อ-iphone' },
  { label: 'กล้อง / เลนส์', href: '/บริการ/รับซื้อกล้อง' },
  { label: 'คอมบริษัท / ยกล็อต', href: '/บริการ/รับซื้อคอมบริษัท' },
  { label: 'Server / Network / UPS', href: '/บริการ/รับซื้อ-server-network' },
  { label: 'เครื่องมีตำหนิ / เสีย', href: '/บริการ/รับซื้อโน๊ตบุ๊ค' },
].map((cat) => ({
  ...cat,
  ...(categoryImages[cat.href] ?? {
    src: '/images/hero/hero-amphon-trading-rub-sue-it-isan.webp',
    alt: imageAlt['/images/hero/hero-amphon-trading-rub-sue-it-isan.webp'],
  }),
}));

const b2bServices = [
  {
    title: 'รับซื้อคอมสำนักงาน',
    href: '/บริการ/รับซื้อคอมสำนักงาน',
    desc: 'คอมออฟฟิศหลายเครื่อง ส่งรายการหรือรูปประเมินเบื้องต้นได้',
  },
  {
    title: 'รับซื้อคอมบริษัท',
    href: '/บริการ/รับซื้อคอมบริษัท',
    desc: 'อุปกรณ์ไอทีองค์กร รับพิจารณาทั่วประเทศ',
  },
  {
    title: 'รับซื้อคอมยกล็อต',
    href: '/บริการ/รับซื้อคอมยกล็อต',
    desc: 'งานยกล็อตหลายเครื่อง ส่ง Inventory List ประเมินได้',
  },
  {
    title: 'รับซื้อคอมบริษัทปิดกิจการ',
    href: '/บริการ/รับซื้อคอมบริษัทปิดกิจการ',
    desc: 'เคลียร์อุปกรณ์ไอทีเมื่อปิดกิจการหรือย้ายสำนักงาน',
  },
  {
    title: 'รับเคลียร์อุปกรณ์ไอทีสำนักงาน',
    href: '/บริการ/รับเคลียร์อุปกรณ์ไอทีสำนักงาน',
    desc: 'รับพิจารณาอุปกรณ์สำนักงานคงเหลือทั่วประเทศ',
  },
  {
    title: 'รับซื้ออุปกรณ์ไอทีบริษัท',
    href: '/บริการ/รับซื้ออุปกรณ์ไอทีบริษัท',
    desc: 'Server, Network, UPS และอุปกรณ์ไอทีองค์กร',
  },
  {
    title: 'รับประมูลคอมพิวเตอร์มือสอง',
    href: '/บริการ/รับประมูลคอมพิวเตอร์มือสอง',
    desc: 'งานประมูลและล็อตคอมมือสอง ติดต่อสอบถามรายละเอียด',
  },
];

const fullAddress = [site.address.street, site.address.locality, site.address.region, site.address['postalCode']].join(' ');

const computerHubLinks = [
  {
    title: 'รับซื้อคอมพิวเตอร์ตั้งโต๊ะ',
    href: '/บริการ/รับซื้อคอมพิวเตอร์ตั้งโต๊ะ',
    desc: 'สำหรับคอมตั้งโต๊ะทั่วไป Desktop PC และเครื่องมือสองที่ต้องการแยกบริบทให้ชัด',
  },
  {
    title: 'รับซื้อ Gaming PC',
    href: '/บริการ/รับซื้อ-gaming-pc',
    desc: 'เป็นทางเข้าหลักสำหรับคอมเล่นเกม คอมร้านเกม และคอมสตรีมเกม',
  },
  {
    title: 'รับซื้อ Workstation',
    href: '/บริการ/รับซื้อ-workstation',
    desc: 'เหมาะกับเครื่องทำงานกราฟิก ตัดต่อ งาน 3D งาน CAD และคอม AI / Deep Learning',
  },
  {
    title: 'รับซื้อคอมบริษัท',
    href: '/บริการ/รับซื้อคอมบริษัท',
    desc: 'สำหรับงานรับซื้อคอมหลายเครื่อง งานยกล็อต และอุปกรณ์ไอทีขององค์กร',
  },
  {
    title: 'รับซื้อโน๊ตบุ๊ค',
    href: '/บริการ/รับซื้อโน๊ตบุ๊ค',
    desc: 'เป็น Hub สำหรับโน๊ตบุ๊คทั่วไป สายทำงาน สายเกม และโน๊ตบุ๊คบริษัท',
  },
];

const trustPhotos = [
  {
    src: '/images/about/amphon-trading-storefront-ubon.webp',
    title: 'มีหน้าร้านจริง ตรวจสอบได้',
    desc: '740/8 ถนนชยางกูร ตำบลในเมือง อำเภอเมืองอุบลราชธานี',
  },
  {
    src: '/images/about/amphon-trading-shop-interior-evaluation.webp',
    title: 'ตรวจสอบและจ่ายเงินเมื่อตกลงราคา',
    desc: 'ทีมงานตรวจสภาพเครื่องจริง โอนเงินหรือเงินสดหลังตกลงราคา',
  },
  {
    src: '/images/about/amphon-trading-shop-showroom.webp',
    title: 'ประเมินราคาตามสภาพจริง',
    desc: 'ทีมงานด้านไอที ตรวจสเปกและสภาพเครื่องอย่างละเอียด',
  },
];

const trustItems = [
  { icon: '🏪', title: 'มีหน้าร้านจริงที่อุบลราชธานี',    desc: '740/8 ถนนชยางกูร ตรวจสอบได้ ลูกค้าใกล้เคียงนำสินค้าเข้าร้านได้' },
  { icon: '📸', title: 'ส่งรูปประเมินก่อน ไม่บังคับขาย',   desc: 'ลูกค้าทั่วประเทศส่งรูปหรือรายการสินค้าทาง LINE ได้ก่อนตัดสินใจ' },
  { icon: '🏢', title: 'รับทั้งลูกค้าทั่วไปและบริษัท',     desc: 'รองรับงานยกล็อต Inventory List และอุปกรณ์ไอทีองค์กรทั่วประเทศ' },
  { icon: '📦', title: 'รับซื้อหลายหมวดสินค้าไอที',       desc: 'โน๊ตบุ๊ค มือถือ MacBook คอม กล้อง Server และอุปกรณ์สำนักงาน' },
  { icon: '💯', title: 'ประเมินตามสภาพจริง',              desc: 'ตรวจสเปกและสภาพเครื่องก่อนเสนอราคา โปร่งใส ไม่กดราคาหน้างาน' },
  { icon: '💬', title: 'ติดต่อได้ทาง LINE และโทร',        desc: 'แชท LINE @webuy หรือโทร 064-257-9353 สอบถามและส่งรูปได้สะดวก' },
];
---

<BaseLayout
  title="รับซื้อสินค้าไอทีมือสองทั่วประเทศ | AMPHON TRADING"
  description="อำพล เทรดดิ้ง รับซื้อโน๊ตบุ๊ค คอม iPhone iPad MacBook กล้อง และสินค้าไอทีมือสองทั่วประเทศ ส่งรูปหรือรายการสินค้าเพื่อประเมินราคาเบื้องต้นได้"
  canonical={pageUrl}
  ogImage="/images/og/og-home.webp"
  breadcrumbs={breadcrumbs}
  pageType="WebPage"
  mainEntityId={schemaIds.offerCatalog(pageUrl)}
  schemaExtras={schemaExtras}
>
  <!-- ====== HERO ====== -->
  <section class="hero hero--fullbg">
    <!-- Background image -->
    <div class="hero__bg-img" aria-hidden="true">
      <img
        src="/images/hero/hero-amphon-showroom-rub-sue-it-isan.webp"
        alt=""
        width="1400"
        height="788"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;"
      />
    </div>
    <!-- Gradient overlay for text readability -->
    <div class="hero__bg-overlay" aria-hidden="true"></div>

    <div class="container hero__inner hero__inner--overlay" role="img" aria-label="อำพล เทรดดิ้ง รับซื้อสินค้าไอทีมือสองทั่วประเทศ — โน๊ตบุ๊ค MacBook iPhone iPad คอมพิวเตอร์ กล้อง">
      <!-- Left: copy panel -->
      <div class="hero__copy hero__copy--glass">
        <span class="tag tag--orange" style="margin-bottom:1rem;">อำพล เทรดดิ้ง · รับซื้อทั่วประเทศ</span>
        <h1>รับซื้อสินค้าไอทีมือสองทั่วประเทศ<br/>ส่งรูปประเมินฟรี</h1>
        <p class="hero__subtitle">
          อำพล เทรดดิ้ง รับซื้อโน๊ตบุ๊ค คอมพิวเตอร์ iPhone iPad MacBook กล้อง และอุปกรณ์ไอทีจากลูกค้าทั่วประเทศ<br/>
          ส่งรูปหรือรายการสินค้าเพื่อประเมินราคาเบื้องต้นได้ · มีหน้าร้านจริงที่อุบลราชธานี ตรวจสอบได้
        </p>
        <div class="hero__actions">
          <a href={site.line} class="btn btn--line btn--lg" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 5.92 2 10.72c0 3.46 2.19 6.49 5.49 8.14-.19.68-.72 2.47-.83 2.86-.12.44.16.43.34.31.14-.09 2.26-1.52 3.17-2.14.59.09 1.2.13 1.83.13 5.52 0 10-3.92 10-8.72S17.52 2 12 2z"/></svg>
            ส่งรูปประเมินทาง LINE @webuy
          </a>
          <a href={`tel:${site.phoneTel}`} class="btn btn--ghost">
            📞 โทร {site.phone}
          </a>
          <a href="/รับซื้อสินค้าไอที" class="btn btn--ghost">
            ดูสินค้าที่รับซื้อ →
          </a>
        </div>
        <div class="hero__trust">
          <span class="trust-badge"><span class="trust-badge__icon">✓</span> มีหน้าร้านจริง ตรวจสอบได้</span>
          <span class="trust-badge"><span class="trust-badge__icon">✓</span> รับซื้อหลายหมวดสินค้าไอที</span>
          <span class="trust-badge"><span class="trust-badge__icon">✓</span> รองรับลูกค้าทั่วประเทศ</span>
          <span class="trust-badge"><span class="trust-badge__icon">✓</span> ส่งรูปประเมินเบื้องต้นได้</span>
        </div>

        <!-- Stats bar -->
        <div class="hero__stats">
          <div class="hero__stat">
            <span class="hero__stat-value">ทั่วประเทศ</span>
            <span class="hero__stat-label">รับซื้อออนไลน์</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-value">6+</span>
            <span class="hero__stat-label">หมวดสินค้าไอที</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-value">ฟรี</span>
            <span class="hero__stat-label">ประเมินจากรูป</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-value">24 ชม.</span>
            <span class="hero__stat-label">LINE @webuy</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== CATEGORY GRID ====== -->
  <section class="section section--sm">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">สินค้าที่รับซื้อ</span>
        <h2>รับซื้ออะไรบ้าง?</h2>
        <p>รับซื้อสินค้าไอทีมือสองหลายหมวดจากลูกค้าทั่วประเทศ ส่งรูปเช็กราคาได้ ประเมินตามสภาพจริง เหมาะกับทั้งลูกค้าทั่วไปและองค์กร</p>
      </div>
      <div class="cat-grid">
        {categories.map((cat) => (
          <a href={cat.href} class="cat-card cat-card--image">
            <OptimizedImage src={cat.src} alt={cat.alt} class="cat-card__thumb" loading="lazy" width={300} height={188} />
            <span class="cat-card__label">{cat.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      <div class="section-header section-header--left">
        <span class="eyebrow">ทางลัดหมวดคอมพิวเตอร์</span>
        <h2>Desktop / Gaming PC / Workstation</h2>
        <p>หากต้องการไปหมวดคอมพิวเตอร์แบบเจาะจง ใช้ Hub หลักด้านล่างเพื่อไปต่อยังหน้าย่อยที่เกี่ยวข้อง</p>
      </div>
      <div class="grid grid--3">
        {computerHubLinks.map((item) => (
          <a href={item.href} class="card b2b-card">
            <h3 class="b2b-card__title">{item.title}</h3>
            <p class="b2b-card__desc">{item.desc}</p>
            <span class="b2b-card__link">ดูรายละเอียด →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== HOW IT WORKS ====== -->
  <section class="section section--gray">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">ขั้นตอน</span>
        <h2>ขายสินค้าไอทีกับเรา ง่ายใน 4 ขั้นตอน</h2>
        <p>ลูกค้าใกล้อุบลราชธานีสามารถนำสินค้ามาที่หน้าร้านได้ ส่วนลูกค้าต่างจังหวัดส่งรูปหรือรายการสินค้าเพื่อประเมินเบื้องต้นก่อน แล้วค่อยคุยวิธีจัดส่งหรือนัดหมายตามความเหมาะสม</p>
      </div>
      <div class="steps">
        <div class="step">
          <span class="step__number">1</span>
          <h3 class="step__title">ส่งรูปหรือรายการสินค้า</h3>
          <p class="step__desc">ถ่ายรูปสินค้า ระบุรุ่น สภาพ และอุปกรณ์ที่มีมาด้วย หรือส่ง Inventory List ผ่าน LINE @webuy</p>
        </div>
        <div class="step">
          <span class="step__number">2</span>
          <h3 class="step__title">ประเมินราคาเบื้องต้น</h3>
          <p class="step__desc">ทีมงานตรวจสเปกและแจ้งราคาเบื้องต้นหลังได้รับข้อมูลครบในช่วงเวลาทำการ ไม่มีค่าใช้จ่าย</p>
        </div>
        <div class="step">
          <span class="step__number">3</span>
          <h3 class="step__title">นัดตรวจเช็ก / จัดส่ง / เข้าร้าน</h3>
          <p class="step__desc">เลือกวิธีที่เหมาะสมตามประเภทสินค้า จำนวน และพื้นที่ — เข้าร้านที่อุบลราชธานี นัดรับ หรือจัดส่งตามที่ตกลง</p>
        </div>
        <div class="step">
          <span class="step__number">4</span>
          <h3 class="step__title">ตรวจสอบและจ่ายเงิน</h3>
          <p class="step__desc">ตรวจสภาพเครื่องจริง และชำระเงินหลังตรวจสอบสินค้าและตกลงราคา</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== SERVICES ====== -->
  <section class="section">
    <div class="container">
      <div class="section-header section-header--left">
        <span class="eyebrow">บริการรับซื้อ</span>
        <h2>บริการรับซื้อยอดนิยม</h2>
        <p>รับซื้อสินค้าไอทีมือสองหลายชนิดจากลูกค้าทั่วประเทศ ส่งรูปเช็กราคาได้ ประเมินตามสภาพจริง</p>
      </div>
      <div class="grid grid--2">
        {services.slice(0, 4).map((service) => {
          const cardCopy = homepageServiceCardCopy[service.data.slug];
          return (
          <ServiceCard
            title={cardCopy?.title ?? service.data.title}
            description={cardCopy?.description ?? service.data.description}
            href={`/บริการ/${service.data.slug}`}
            keyword={service.data.mainKeyword}
            image={service.data.heroImage || serviceThumbnails[service.data.slug]}
            imageAlt={cardCopy?.imageAlt}
          />
          );
        })}
      </div>
      <p class="text-center mt-6">
        <a href="/รับซื้อสินค้าไอที" class="btn btn--primary">ดูบริการทั้งหมด →</a>
      </p>
    </div>
  </section>

  <!-- ====== B2B SERVICES ====== -->
  <section class="section section--gray">
    <div class="container">
      <div class="section-header section-header--left">
        <span class="eyebrow">บริการสำหรับบริษัท</span>
        <h2>รับซื้ออุปกรณ์ไอทีองค์กรทั่วประเทศ</h2>
        <p>รองรับงานคอมสำนักงาน ยกล็อต และเคลียร์อุปกรณ์ไอทีเมื่อปิดกิจการหรือย้ายสำนักงาน ส่งรายการหรือรูปประเมินเบื้องต้นได้</p>
      </div>
      <div class="grid grid--3">
        {b2bServices.map((item) => (
          <a href={item.href} class="card b2b-card">
            <h3 class="b2b-card__title">{item.title}</h3>
            <p class="b2b-card__desc">{item.desc}</p>
            <span class="b2b-card__link">ดูรายละเอียด →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== CTA BAND ====== -->
  <CTAContact />

  <!-- ====== TRUST ====== -->
  <section class="section section--gray">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">ทำไมต้องเลือกเรา</span>
        <h2>ทำไมลูกค้าทั่วประเทศเลือกส่งรูปประเมินกับ AMPHON TRADING</h2>
        <p>
          เราไม่ใช่แค่ร้านรับซื้อทั่วไป แต่เป็นผู้เชี่ยวชาญด้านฮาร์ดแวร์และอุปกรณ์ไอที
          ที่ตรวจสอบรุ่น สภาพ อุปกรณ์ และราคาตลาดมือสองก่อนเสนอราคา
          ลูกค้าทั่วประเทศส่งรูปหรือรายการสินค้าประเมินเบื้องต้นได้ มีหน้าร้านจริงที่อุบลราชธานีเป็นหลักฐานความน่าเชื่อถือ
        </p>
      </div>
      <div class="grid grid--3">
        {trustItems.map((item) => (
          <div class="card trust-card" style="flex-direction:row;">
            <div class="trust-card__icon" aria-hidden="true">{item.icon}</div>
            <div class="trust-card__body">
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="company-trust card">
        <div class="company-trust__content">
          <span class="eyebrow">ข้อมูลร้าน</span>
          <h3 class="company-trust__name">บริษัท อำพล เทรดดิ้ง จำกัด</h3>
          <p class="company-trust__tagline">รับซื้อสินค้าไอทีมือสองทั่วประเทศ · มีหน้าร้านจริงที่อุบลราชธานี</p>
          <ul class="company-trust__list">
            <li><strong>ที่อยู่:</strong> {fullAddress}</li>
            <li><strong>โทร:</strong> <a href={`tel:${site.phoneTel}`}>{site.phone}</a></li>
            <li><strong>LINE:</strong> <a href={site.line} target="_blank" rel="noopener noreferrer">{site.lineId}</a></li>
            <li><strong>เวลาเปิด:</strong> 09:00–21:00 น. ทุกวัน</li>
          </ul>
          <div class="company-trust__actions">
            <a href={site.line} class="btn btn--line" target="_blank" rel="noopener noreferrer">แชท Line ประเมินราคา</a>
            <a href={`tel:${site.phoneTel}`} class="btn btn--outline">โทร {site.phone}</a>
            <a href={site.hasMap} class="btn btn--ghost" target="_blank" rel="noopener noreferrer">ดูแผนที่ร้าน</a>
          </div>
        </div>
        <div class="company-trust__photos">
          <figure class="company-trust__photo">
            <OptimizedImage
              src="/images/about/amphon-trading-storefront-ubon.webp"
              alt={imageAlt['/images/about/amphon-trading-storefront-ubon.webp'] ?? 'หน้าร้านอำพล เทรดดิ้ง อุบลราชธานี' }
              loading="lazy"
              width={480}
              height={300}
            />
            <figcaption>หน้าร้าน 740/8 ถนนชยางกูร อุบลราชธานี</figcaption>
          </figure>
          <figure class="company-trust__photo">
            <OptimizedImage
              src="/images/about/amphon-trading-shop-interior-evaluation.webp"
              alt={imageAlt['/images/about/amphon-trading-shop-interior-evaluation.webp'] ?? 'โต๊ะตรวจเช็กและประเมินราคาสินค้าไอที' }
              loading="lazy"
              width={480}
              height={300}
            />
            <figcaption>โต๊ะตรวจเช็กและประเมินราคาตามสภาพจริง</figcaption>
          </figure>
        </div>
      </div>

      <div class="about-gallery" style="margin-top:2.5rem;">
        {trustPhotos.map((photo) => (
          <figure class="about-gallery__item">
            <OptimizedImage src={photo.src} alt={imageAlt[photo.src] ?? photo.title} loading="lazy" width={600} height={375} />
            <figcaption><strong>{photo.title}</strong> — {photo.desc}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== AREAS ====== -->
  <section class="section">
    <div class="container">
      <div class="section-header section-header--left">
        <span class="eyebrow">พื้นที่ให้บริการ</span>
        <h2>พื้นที่ที่สะดวกสำหรับนัดรับและเข้าร้าน</h2>
        <p>มีหน้าร้านที่อุบลราชธานี ลูกค้าใกล้เคียงนำสินค้าเข้าร้านได้ การนัดรับหรือประสานขนส่งขึ้นอยู่กับประเภทสินค้า จำนวน และพื้นที่</p>
      </div>
      <ProvinceGrid
        provinces={areas.map((area) => ({
          title: area.data.title,
          slug: area.data.slug,
          description: area.data.description,
        }))}
      />
      <p class="text-center mt-6">
        <a href="/พื้นที่ให้บริการ" class="btn btn--outline">ดูพื้นที่ให้บริการทั้งหมด →</a>
      </p>
    </div>
  </section>

  <!-- ====== BLOG ====== -->
  {posts.length > 0 && (
    <section class="section section--gray">
      <div class="container">
        <div class="section-header section-header--left">
          <span class="eyebrow">บทความความรู้</span>
          <h2>เคล็ดลับก่อนขายสินค้าไอที</h2>
          <p>อ่านก่อนขาย เพื่อเตรียมข้อมูลให้ครบและได้ราคาที่เหมาะสม</p>
        </div>
        <div class="grid grid--3">
          {posts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              href={`/blog/${post.data.slug}`}
              date={post.data.date}
              tags={post.data.tags}
              image={post.data.heroImage}
              imageAlt={post.data.title}
            />
          ))}
        </div>
        <p class="text-center mt-6">
          <a href="/blog" class="btn btn--outline">อ่านบทความทั้งหมด →</a>
        </p>
      </div>
    </section>
  )}

  <RescueLinkGroups
    eyebrow="ลิงก์ช่วยจัดอันดับ"
    title="รวมลิงก์ไปหน้าบริการที่ควรให้ Google เจอชัดขึ้น"
    description="ใช้ส่วนนี้เป็น internal-link hub จากหน้าแรกไปยังหน้าบริการหลักและหน้ารุ่นย่อยที่ยังควรเก็บ index เพื่อช่วยกระจายน้ำหนักลิงก์และลดสถานะ discovered หรือ crawled but not indexed."
    groups={rescueGroups}
  />

  <!-- ====== FAQ ====== -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">คำถามที่พบบ่อย (FAQ)</span>
        <h2>ข้อสงสัยเกี่ยวกับการรับซื้อสินค้าไอที</h2>
      </div>
      <div class="grid grid--2" style="gap:2rem;">
        <div class="card">
          <h3 style="margin-bottom:0.5rem;font-size:1.1rem;">Q: ประเมินราคาฟรีจริงไหม ใช้เวลานานแค่ไหน?</h3>
          <p class="text-sm">A: ประเมินฟรี ไม่มีค่าใช้จ่ายครับ เพียงแอดไลน์และส่งรูปสินค้าพร้อมสเปกให้เรา ทีมงานจะแจ้งราคาประเมินเบื้องต้นหลังได้รับข้อมูลครบในช่วงเวลาทำการ</p>
        </div>
        <div class="card">
          <h3 style="margin-bottom:0.5rem;font-size:1.1rem;">Q: อยู่ต่างจังหวัด ส่งรูปประเมินได้ไหม?</h3>
          <p class="text-sm">A: ได้ครับ ลูกค้าทั่วประเทศส่งรูปหรือรายการสินค้าทาง LINE @webuy เพื่อประเมินราคาเบื้องต้นได้ก่อน จากนั้นค่อยคุยวิธีจัดส่งหรือนัดหมายตามประเภทสินค้าและพื้นที่</p>
        </div>
        <div class="card">
          <h3 style="margin-bottom:0.5rem;font-size:1.1rem;">Q: ข้อมูลในเครื่องจะหลุดไหม?</h3>
          <p class="text-sm">A: ทางร้านดำเนินการล้างข้อมูล (Format/Wipe Data) ตามขั้นตอนหลังรับซื้อเครื่องเข้ามา เพื่อปกป้องความเป็นส่วนตัวของลูกค้า</p>
        </div>
        <div class="card">
          <h3 style="margin-bottom:0.5rem;font-size:1.1rem;">Q: รับซื้อเครื่องเสีย หรือเครื่องติดล็อคไหม?</h3>
          <p class="text-sm">A: ส่วนใหญ่เรารับซื้อเครื่องที่ใช้งานได้ปกติ หรือมีตำหนิภายนอกครับ สำหรับเครื่องเสียรบกวนส่งอาการให้ช่างประเมินก่อน (งดรับเครื่องขโมยหรือติด iCloud/รหัสผ่านทุกกรณี)</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FINAL CTA ====== -->
  <CTAContact />
</BaseLayout>

