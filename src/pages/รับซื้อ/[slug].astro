---
import { getCollection } from 'astro:content';
import ServiceAreaLayout from '../../layouts/ServiceAreaLayout.astro';
import { filterIndexableServiceAreas } from '../../config/seo-policy';

export async function getStaticPaths() {
  const serviceAreas = filterIndexableServiceAreas(
    await getCollection('serviceAreas', ({ data }) => !data.draft),
  );
  const services = await getCollection(
    'services',
    ({ data }) => !data.draft || data.slug === 'รับซื้อสินค้าไอที',
  );
  const areas = await getCollection('areas', ({ data }) => !data.draft);

  return serviceAreas.map((entry) => ({
    params: { slug: entry.data.slug },
    props: {
      entry,
      service: services.find((s) => s.data.slug === entry.data.serviceSlug),
      area: areas.find((a) => a.data.slug === entry.data.areaSlug),
    },
  }));
}

const { entry, service, area } = Astro.props;
---

<ServiceAreaLayout entry={entry} service={service} area={area} />
